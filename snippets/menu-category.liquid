<li class="menu-link" {{ block.shopify_attributes }}>
  <a
    href="{{ block.settings.menu_product_url }}"
    class="link-title"
    style="--font-size: {{ section.settings.menu_font_size }}px; --font-size-lg: {{ section.settings.menu_font_size_lg }}px;  --text-transform: {{ section.settings.menu_text_transform }};  --font-weight: {{ section.settings.menu_font_weight }};"
  >
    <span class="sp-link-title">
      {{- block.settings.menu_product_title -}}
      {%- if block.settings.menu_product_label != '' -%}
        <span class="{{ section.id }}-{{ block.id }}-label">{{ block.settings.menu_product_label }}</span>
      {%- endif -%}
    </span>
    <span class="menu-arrow"><i class="feather-chevron-down"></i></span>
  </a>
  <div class="link-title-lg">
    <a href="{{ block.settings.menu_product_url }}" class="sp-link-title">{{ block.settings.menu_product_title }}</a>
    <button
      type="button" data-bs-toggle="collapse"
      data-bs-target="#single-collapse-{{ block.settings.menu_product_title | handleize }}"
      class="menu-arrow dropdown-btn"
      aria-label="{{ block.settings.menu_product_title | handleize }}"
    >
      <i class="feather-plus"></i>
    </button>
  </div>
  <ul
    class="list-unstyled menu-dropdown menu-category dropdown-content collapse"
    id="single-collapse-{{ block.settings.menu_product_title | handleize }}"
  >
    <div class="container-fluid">
      <div class="ul">
        
          {% assign menu_product_select = block.settings.menu_product_select %}
          {% if menu_product_select != '' %}
              <li class="productlink-li">
          {% for link in linklists[menu_product_select].links %}
            {% assign sublink = link.title | handle %}
            
                <a href="{{ link.url }}" class="productlink-title">
                  <span class="sp-link-title">{{ link.title }}</span>
                </a>
                <div class="productlink-title productlink-title-lg">
                  <a href="{{ link.url }}" class="sp-link-title">{{ link.title }}</a>
                  {% if linklists[sublink].links != '' %}
                  <button
                    type="button" data-bs-toggle="collapse"
                    data-bs-target="#productsup-collapse-{{ link.title | handleize }}"
                    class="menu-arrow dropdown-btn"
                    aria-label="{{ link.title | handleize }}"
                  >
                    <i class="feather-plus"></i>
                  </button>
                  {% endif %}
                </div>
                {% if linklists[sublink].links != '' %}
                <ul
                  class="list-unstyled productsupmenu-dropdown dropdown-content collapse"
                  id="productsup-collapse-{{ link.title | handleize }}"
                >
                  {% for sublink in linklists[sublink].links %}
                    <li class="productsupmenu-li">
                      <a href="{{ sublink.url }}" class="productsuplink-title">
                        <span class="sp-link-title">{{ sublink.title }}</span>
                      </a>
                    </li>
                  {% endfor %}
                </ul>
            {% endif %}
          {% endfor %}
              </li>
            {% endif %}
        
