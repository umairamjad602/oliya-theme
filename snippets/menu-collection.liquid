<li class="menu-link menu-collection-block" {{ block.shopify_attributes }}>

  {%- comment -%} Desktop top-level link {%- endcomment -%}
  <a
    href="{{ block.settings.menu_collection_url }}"
    class="link-title"
    style="--font-size: {{ section.settings.menu_font_size }}px; --font-size-lg: {{ section.settings.menu_font_size_lg }}px; --text-transform: {{ section.settings.menu_text_transform }}; --font-weight: {{ section.settings.menu_font_weight }};"
  >
    <span class="sp-link-title">
      {{- block.settings.menu_collection_title -}}
      {%- if block.settings.menu_collection_label != blank -%}
        <span class="{{ section.id }}-{{ block.id }}-label">{{ block.settings.menu_collection_label }}</span>
      {%- endif -%}
    </span>
    <span class="menu-arrow"><i class="feather-chevron-down"></i></span>
  </a>

  {%- comment -%} Mobile accordion header {%- endcomment -%}
  <div class="link-title-lg">
    <a href="{{ block.settings.menu_collection_url }}" class="sp-link-title">
      {{- block.settings.menu_collection_title -}}
    </a>
    <button
      type="button"
      class="menu-arrow dropdown-btn mc-mobile-toggle"
      aria-expanded="false"
      aria-controls="mcol-mobile-{{ block.id }}"
      aria-label="{{ block.settings.menu_collection_title | handleize }}"
    >
      <i class="feather-plus"></i>
    </button>
  </div>

  {%- comment -%} Desktop mega menu — full-width horizontal collection list {%- endcomment -%}
  <ul class="list-unstyled menu-dropdown mc-mega-menu">
    <li class="mc-inner">
      <div class="mc-collections-row">

        {%- if block.settings.menu_collection_linklist != blank -%}
          {%- for link in linklists[block.settings.menu_collection_linklist].links -%}
            {%- liquid
              assign col_handle = link.url | split: '/' | last | split: '?' | first
              assign col = collections[col_handle]
              assign col_img = nil
              if col.image != blank
                assign col_img = col.image
              elsif col.products.first != blank and col.products.first.featured_image != blank
                assign col_img = col.products.first.featured_image
              endif
            -%}
            <a href="{{ link.url }}" class="mc-col-card">
              <div class="mc-col-img-wrap">
                {%- if col_img != blank -%}
                  {{
                    col_img
                    | image_url: width: 400
                    | image_tag:
                      loading: 'lazy',
                      alt: link.title,
                      class: 'mc-col-img'
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'mc-col-img placeholder-svg' }}
                {%- endif -%}
              </div>
              <span class="mc-col-title">{{ link.title }}</span>
            </a>
          {%- endfor -%}
        {%- endif -%}

        {%- comment -%} "View all" card at the end {%- endcomment -%}
        {%- if block.settings.menu_collection_all_url != blank -%}
          <a href="{{ block.settings.menu_collection_all_url }}" class="mc-col-card mc-col-viewall-card">
            <div class="mc-col-img-wrap mc-col-viewall-inner">
              <i class="feather-grid"></i>
              <span>{{ block.settings.menu_collection_all_button | default: 'View All' }}</span>
            </div>
          </a>
        {%- endif -%}

      </div>
    </li>
  </ul>

  {%- comment -%} Mobile collapsible panel {%- endcomment -%}
  <div class="mc-mobile-panel" id="mcol-mobile-{{ block.id }}" style="display:none;">
    {%- if block.settings.menu_collection_linklist != blank -%}
      {%- for link in linklists[block.settings.menu_collection_linklist].links -%}
        <a href="{{ link.url }}" class="mc-link-item">{{ link.title }}</a>
      {%- endfor -%}
    {%- endif -%}
    {%- if block.settings.menu_collection_all_url != blank -%}
      <a href="{{ block.settings.menu_collection_all_url }}" class="mc-link-item mc-view-all">
        {{ block.settings.menu_collection_all_button | default: 'View All' }}
      </a>
    {%- endif -%}
  </div>

</li>

<style>
  a.link-title span.sp-link-title span.{{ section.id }}-{{ block.id }}-label {
    color: {{ block.settings.menu_collection_label_color }};
    font-size: {{ block.settings.menu_collection_label_font_size }}px;
    padding: 2px 5px;
    position: absolute;
    top: -{{ block.settings.menu_collection_label_top_position }}px;
    right: 0;
    transform: translateX(100%);
    background-color: {{ block.settings.menu_collection_label_bgcolor }};
    text-transform: {{ block.settings.menu_collection_label_text_transform }};
    border-radius: {{ block.settings.menu_collection_label_border_radius }}px;
    line-height: 1.2;
  }
  @media (max-width: 1199px) {
    a.link-title span.sp-link-title span.{{ section.id }}-{{ block.id }}-label { top: -8px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.querySelector('.mc-mobile-toggle[aria-controls="mcol-mobile-{{ block.id }}"]');
    var panel = document.getElementById('mcol-mobile-{{ block.id }}');
    if (btn && panel) {
      btn.addEventListener('click', function () {
        var open = panel.style.display === 'block';
        panel.style.display = open ? 'none' : 'block';
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        btn.querySelector('i').className = open ? 'feather-plus' : 'feather-minus';
      });
    }
  });
</script>
