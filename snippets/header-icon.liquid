<script src="{{ 'localization-form.js' | asset_url }}" defer></script>
<ul class="shop-element list-unstyled">

  {%- if settings.search_enable -%}
    <li class="side-wrap search-wrap">
      <button class="search-popup header-icon" type="button" data-bs-target="#modal-search" data-bs-toggle="modal" role="button" aria-label="search">
        <i class="ri-search-line"></i>
      </button>
    </li>
  {%- endif -%}

  {%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
    <li class="side-wrap globe-wrap">
      <button class="header-icon globe-btn" type="button" aria-label="Language and currency">
        <i class="ri-global-line"></i>
      </button>
      <div class="globe-dropdown">
        {%- if section.settings.enable_country_selector -%}
          <div class="globe-locali-item">
            <p class="globe-locali-label">Currency</p>
            <localization-form>
              {%- form 'localization', id: 'GlobeCountryForm', class: 'localization-form' -%}
                {%- render 'country-localization', localPosition: 'GlobeCountry' -%}
              {%- endform -%}
            </localization-form>
          </div>
        {%- endif -%}
        {%- if section.settings.enable_language_selector -%}
          <div class="globe-locali-item">
            <p class="globe-locali-label">Language</p>
            <localization-form>
              {%- form 'localization', id: 'GlobeLanguageForm', class: 'localization-form' -%}
                {%- render 'language-localization', localPosition: 'GlobeLanguage' -%}
              {%- endform -%}
            </localization-form>
          </div>
        {%- endif -%}
      </div>
    </li>
  {%- endif -%}

  {% if shop.customer_accounts_enabled %}
  <li class="side-wrap user-wrap">
    <a href="{{ routes.account_url }}" class="header-icon" aria-label="Account">
      <i class="ri-user-line"></i>
    </a>
  </li>
  {% endif %}

  {%- if settings.wishlist_enable -%}
    <li class="side-wrap wishlist-wrap">
      <a class="header-icon" href="{{ settings.wishlist_page_url }}" title="Wishlist">
        <i class="ri-heart-line"></i>
        {%- if settings.wl_title != '' -%}
          <span class="title">{{ settings.wl_title }}</span>
        {%- endif -%}
        <span class="wishlist-counter">{{ wishlist.count }}</span>
      </a>
    </li>
  {%- endif -%}

  {%- if settings.cart_enable -%}
    <li class="side-wrap cart-wrap">
      <a href="{{ routes.cart_url }}" class="header-icon" id="ajax-cart-icon" aria-label="Cart">
        <i class="ri-shopping-bag-line"></i>
        {%- if settings.cart_title != '' -%}
          <span class="title">{{ settings.cart_title }}</span>
        {%- endif -%}
        <div class="ajax-cart-count bigcounter">
          {%- if cart.item_count < 100 -%}
            <span aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
          <span class="visually-hidden">{{ 'sections.cart_count' | t: count: cart.item_count }}</span>
        </div>
      </a>
    </li>
  {%- endif -%}

</ul>
