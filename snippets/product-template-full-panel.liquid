{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
  assign color_label = 'Color,color,colour,couleur,cor,colore,farbe,색,色,カラー,färg,farve,szín,barva' | split: ','
  assign compare_at_price = current_variant.compare_at_price
  assign price = current_variant.price
  assign has_hot_tag = false
  for tag in product.tags
    assign tag_down = tag | downcase
    if tag_down == 'hot'
      assign has_hot_tag = true
    endif
  endfor
-%}

<div class="pdp-panel product-info" {{ block.shopify_attributes }}>

  <!-- Title + Wishlist -->
  <div class="pdp-title-row">
    <h1 class="pdp-title mr-0">{{ product.title | escape | default: 'Example Product Title' }}</h1>
    <button class="pdp-wishlist-btn" type="button" aria-label="Add to wishlist">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
    </button>
  </div>

  <!-- Price + Review Stars -->
  <!-- id="price-{section.id}" is required by the theme JS (includeProInf) to update price on variant change -->
  <div class="pdp-price-stars-row">
    <div class="pdp-price-box price-box{% if compare_at_price > price %} price--on-sale{% endif %}" id="price-{{ section.id }}">
      <span class="pdp-price-current new-price" id="ProductPrice">{{ price | money }}</span>
      <span class="pdp-price-was old-price" id="ComparePrice">
        {%- if compare_at_price > price -%}{{ compare_at_price | money }}{%- endif -%}
      </span>
    </div>
    {%- assign reviews_rating = product.metafields.reviews.rating.value -%}
    {%- assign reviews_count = product.metafields.reviews.rating_count.value -%}
    {%- if reviews_rating != blank -%}
      <div class="pdp-reviews-box">
        <div class="pdp-stars-wrap" title="{{ reviews_rating | round: 1 }} out of 5 stars">
          {%- assign rating_floor = reviews_rating | floor -%}
          {%- assign rating_decimal = reviews_rating | minus: rating_floor -%}
          {%- assign half_star_pos = rating_floor | plus: 1 -%}
          {%- for i in (1..5) -%}
            {%- if i <= rating_floor -%}
              <span class="pdp-star pdp-star--full">&#9733;</span>
            {%- elsif rating_decimal >= 0.5 and i == half_star_pos -%}
              <span class="pdp-star pdp-star--half">&#9733;</span>
            {%- else -%}
              <span class="pdp-star pdp-star--empty">&#9733;</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <a href="#reviews" class="pdp-reviews-link">{{ reviews_count }} &#8250;</a>
      </div>
    {%- endif -%}
  </div>

  <!-- Badges -->
  {%- if has_hot_tag -%}
    <span class="pdp-badge pdp-badge--hot">HOT</span>
  {%- endif -%}
  {%- if compare_at_price > price -%}
    {%- assign discount_pct = compare_at_price | minus: price | times: 100.0 | divided_by: compare_at_price | floor -%}
    <span class="pdp-badge pdp-badge--sale">-{{ discount_pct }}%</span>
  {%- endif -%}

  <!-- Variant Picker -->
  <!-- SwatchCheck (pr-option) requires <varitem> wrappers and radio inputs to detect selections -->
  {%- unless product.has_only_default_variant -%}
    <pr-option
      id="variant-radios-{{ section.id }}"
      class="pdp-variant-picker pr-option"
      data-section="{{ section.id }}"
      data-url="{{ product.url }}"
    >
      {%- for option in product.options_with_values -%}
        {%- liquid
          assign option_downcase = option.name | downcase
          assign is_color = false
          if color_label contains option_downcase
            assign is_color = true
          endif
        -%}

        {%- if is_color -%}
          <varitem class="pdp-option pdp-option--color js variant-option-block">
            <div class="pdp-option-label">
              <span class="pdp-option-name">{{ option.name | upcase }}</span>
              <span class="pdp-option-sep"> / SIZE</span>
            </div>
            <div class="pdp-swatches option-block">
              {%- liquid
                assign variants_available_arr = product.variants | map: 'available'
                assign variants_option1_arr   = product.variants | map: 'option1'
                assign variants_option2_arr   = product.variants | map: 'option2'
                assign variants_option3_arr   = product.variants | map: 'option3'
              -%}
              {%- for value in option.values -%}
                {%- liquid
                  assign option_disabled = true
                  for option1_name in variants_option1_arr
                    case option.position
                      when 1
                        if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
                          assign option_disabled = false
                        endif
                      when 2
                        if option1_name == current_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
                          assign option_disabled = false
                        endif
                      when 3
                        if option1_name == current_variant.option1 and variants_option2_arr[forloop.index0] == current_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
                          assign option_disabled = false
                        endif
                    endcase
                  endfor

                  assign swatch_bg = ''
                  if value.swatch.image
                    assign swatch_img_url = value.swatch.image | image_url: width: 60
                    assign swatch_bg = 'url(' | append: swatch_img_url | append: ') center/cover'
                  elsif value.swatch.color
                    assign swatch_bg = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                  else
                    assign value_key = value | downcase | replace: ' ', '-'
                    case value_key
                      when 'black', 'jet-black', 'jet', 'off-black', 'onyx'
                        assign swatch_bg = '#111111'
                      when 'white', 'off-white', 'ivory', 'cream', 'snow'
                        assign swatch_bg = '#FFFFFF'
                      when 'red', 'bright-red', 'cherry-red', 'scarlet', 'cherry', 'tomato'
                        assign swatch_bg = '#D32F2F'
                      when 'dark-red', 'wine', 'maroon', 'burgundy', 'oxblood'
                        assign swatch_bg = '#7B1A1A'
                      when 'pink', 'hot-pink', 'fuchsia', 'magenta'
                        assign swatch_bg = '#E91E8C'
                      when 'light-pink', 'baby-pink', 'powder-pink', 'pastel-pink', 'soft-pink'
                        assign swatch_bg = '#FFCDD2'
                      when 'blush', 'blush-pink', 'blush-rose'
                        assign swatch_bg = '#F4B8C1'
                      when 'rose', 'dusty-rose', 'vintage-rose'
                        assign swatch_bg = '#C48B9F'
                      when 'mauve', 'dusty-mauve', 'dusty-pink'
                        assign swatch_bg = '#B5737B'
                      when 'coral', 'peach-coral'
                        assign swatch_bg = '#FF6B6B'
                      when 'peach', 'apricot'
                        assign swatch_bg = '#FFCC99'
                      when 'salmon'
                        assign swatch_bg = '#FA8072'
                      when 'orange', 'tangerine', 'burnt-orange', 'amber'
                        assign swatch_bg = '#F57C00'
                      when 'yellow', 'lemon', 'bright-yellow', 'sunshine'
                        assign swatch_bg = '#FDD835'
                      when 'gold', 'mustard', 'mustard-yellow', 'golden', 'honey'
                        assign swatch_bg = '#F9A825'
                      when 'green', 'forest-green', 'dark-green', 'bottle-green'
                        assign swatch_bg = '#2E7D32'
                      when 'light-green', 'lime', 'lime-green', 'apple-green'
                        assign swatch_bg = '#8BC34A'
                      when 'mint', 'mint-green', 'spearmint'
                        assign swatch_bg = '#A5D6A7'
                      when 'sage', 'sage-green', 'eucalyptus'
                        assign swatch_bg = '#87A878'
                      when 'olive', 'army-green', 'military-green', 'khaki-green'
                        assign swatch_bg = '#6D6928'
                      when 'teal', 'dark-teal'
                        assign swatch_bg = '#00796B'
                      when 'emerald', 'emerald-green'
                        assign swatch_bg = '#00695C'
                      when 'blue', 'royal-blue', 'cobalt', 'bright-blue'
                        assign swatch_bg = '#1976D2'
                      when 'light-blue', 'sky-blue', 'baby-blue', 'powder-blue', 'pale-blue'
                        assign swatch_bg = '#90CAF9'
                      when 'navy', 'navy-blue', 'dark-navy', 'midnight-blue', 'midnight', 'midnight-navy'
                        assign swatch_bg = '#0D1B3E'
                      when 'denim', 'chambray', 'steel-blue'
                        assign swatch_bg = '#5C7EA8'
                      when 'turquoise', 'aqua', 'cyan', 'aqua-blue'
                        assign swatch_bg = '#00BCD4'
                      when 'purple', 'violet', 'plum', 'grape'
                        assign swatch_bg = '#7B1FA2'
                      when 'dark-purple', 'deep-purple', 'eggplant'
                        assign swatch_bg = '#4A148C'
                      when 'lavender', 'lilac', 'wisteria'
                        assign swatch_bg = '#CE93D8'
                      when 'gray', 'grey', 'charcoal', 'dark-gray', 'dark-grey', 'slate'
                        assign swatch_bg = '#616161'
                      when 'light-gray', 'light-grey', 'silver', 'ash', 'heather', 'stone'
                        assign swatch_bg = '#BDBDBD'
                      when 'brown', 'chocolate', 'coffee', 'mocha', 'espresso', 'cocoa'
                        assign swatch_bg = '#5D4037'
                      when 'tan', 'camel', 'sand', 'desert', 'latte'
                        assign swatch_bg = '#C8A882'
                      when 'beige', 'natural', 'nude', 'khaki', 'wheat'
                        assign swatch_bg = '#D7CCC8'
                      when 'leopard', 'animal', 'animal-print', 'cheetah'
                        assign swatch_bg = 'repeating-linear-gradient(45deg,#C9A84C,#C9A84C 4px,#3B2A00 4px,#3B2A00 8px)'
                      when 'stripe', 'stripes', 'striped'
                        assign swatch_bg = 'repeating-linear-gradient(90deg,#444 0,#444 4px,#fff 4px,#fff 8px)'
                      else
                        assign swatch_bg = value | downcase | replace: ' ', ''
                    endcase
                  endif

                  assign color_input_id = section.id | append: '-opt' | append: option.position | append: '-' | append: forloop.index0
                -%}
                <input
                  type="radio"
                  id="{{ color_input_id }}"
                  name="{{ option.name }}"
                  value="{{ value | escape }}"
                  form="{{ product_form_id }}"
                  {% if option.selected_value == value %}checked{% endif %}
                  {% if option_disabled %}class="disabled"{% endif %}
                >
                <label
                  for="{{ color_input_id }}"
                  class="op-lb color pdp-swatch-label{% if option_disabled %} disabled{% endif %}"
                  title="{{ value }}"
                >
                  <span class="pdp-color-dot" style="background: {{ swatch_bg }};"></span>
                  <span class="visually-hidden">{{ value }}</span>
                </label>
              {%- endfor -%}
            </div>
          </varitem>

        {%- else -%}
          <varitem class="pdp-option pdp-option--size js variant-option-block">
            <div class="pdp-size-header-row">
              <div class="pdp-size-chart-wrap">
                <select class="pdp-size-chart-select" aria-label="Size chart type">
                  {%- if block.settings.size_chart_options != blank -%}
                    {%- assign chart_options = block.settings.size_chart_options | split: ',' -%}
                    {%- for chart_opt in chart_options -%}
                      <option>{{ chart_opt | strip }}</option>
                    {%- endfor -%}
                  {%- else -%}
                    <option>Standard Size</option>
                    <option>US Size</option>
                    <option>UK Size</option>
                    <option>EU Size</option>
                  {%- endif -%}
                </select>
                <svg class="pdp-select-caret" xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              {%- if block.settings.size_guide_url != blank -%}
                <a href="{{ block.settings.size_guide_url }}" class="pdp-more-sizes-link">{{ block.settings.more_sizing_text | default: 'More Sizing Options' }}</a>
              {%- else -%}
                <span class="pdp-more-sizes-link">{{ block.settings.more_sizing_text | default: 'More Sizing Options' }}</span>
              {%- endif -%}
            </div>
            <div class="pdp-size-pills option-block">
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: 'button'
              %}
            </div>
          </varitem>
        {%- endif -%}

      {%- endfor -%}

      <script type="application/json">
        {{ product.variants | json }}
      </script>
    </pr-option>
  {%- endunless -%}

  <!-- Size Guide Bar -->
  {%- if block.settings.size_guide_enable -%}
    <div class="pdp-size-guide-bar">
      {%- if block.settings.size_guide_url != blank -%}
        <a href="{{ block.settings.size_guide_url }}" class="pdp-size-guide-trigger">
      {%- else -%}
        <button type="button" class="pdp-size-guide-trigger">
      {%- endif -%}
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
          {{ block.settings.size_guide_text | default: 'SIZE GUIDE' }}
          <svg class="pdp-size-guide-arrow" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      {%- if block.settings.size_guide_url != blank -%}
        </a>
      {%- else -%}
        </button>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- Add to Bag -->
  <!-- cart-action web component handles ajax cart; form id must match product-form-{section.id} -->
  <cart-action class="pdp-atb-section" data-hide-errors="false">
    <div class="pr-form-error" role="alert" hidden>
      <span class="pr-form-error-text"></span>
    </div>
    {%- form 'product', product,
      id: product_form_id,
      class: 'form pdp-product-form',
      novalidate: 'novalidate',
      data-type: 'add-to-cart-form'
    -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}" disabled class="product-variant-id">
      <div class="pr-form-button">
        <div class="ajax-cart-btn">
          <button
            id="ProductSubmitButton-{{ section.id }}"
            type="submit"
            name="add"
            class="pdp-atb-btn"
            {% if current_variant.available == false %}disabled{% endif %}
            aria-label="{{ 'products.product.add_to_cart' | t }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            <span class="cart-title">
              {%- if current_variant.available -%}
                ADD TO BAG
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </span>
            <div class="ajax-loader hidden"><span class="spinner-border"></span></div>
          </button>
        </div>
      </div>
    {%- endform -%}
  </cart-action>

  <div class="pdp-divider"></div>

  <!-- Accordions -->
  <div class="pdp-accordions">

    <!-- Shipping -->
    <div class="pdp-accordion">
      <button
        class="pdp-accordion-header"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#pdp-shipping-{{ section.id }}"
        aria-expanded="false"
      >
        <span>SHIPPING TO <u>{{ localization.country.name | upcase | default: shop.address.country | upcase }}</u></span>
        <svg class="pdp-chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <div class="collapse" id="pdp-shipping-{{ section.id }}">
        <div class="pdp-accordion-body">

          <div class="pdp-shipping-row">
            <button
              class="pdp-shipping-row-btn"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#pdp-delivery-{{ section.id }}"
              aria-expanded="false"
            >
              <span class="pdp-ship-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              </span>
              <span>Delivery</span>
              <svg class="pdp-chevron-sm" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
            <div class="collapse" id="pdp-delivery-{{ section.id }}">
              <div class="pdp-delivery-info">
                <p>{{ block.settings.free_shipping_text | default: 'Free Standard Shipping Over $99.00' }}</p>
                <p>{{ block.settings.shipping_time_text | default: 'Shipping Time: 10 - 20 days' }}</p>
              </div>
            </div>
          </div>

          <div class="pdp-shipping-row">
            <button
              class="pdp-shipping-row-btn"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#pdp-return-{{ section.id }}"
              aria-expanded="false"
            >
              <span class="pdp-ship-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 .49-3.52"></path></svg>
              </span>
              <span>Return Policy</span>
              <svg class="pdp-chevron-sm" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
            <div class="collapse" id="pdp-return-{{ section.id }}">
              <div class="pdp-delivery-info">
                <p>{{ block.settings.return_policy_text | default: 'Returns accepted within 30 days of delivery date.' }}</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Product Description -->
    <div class="pdp-accordion">
      <button
        class="pdp-accordion-header"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#pdp-desc-{{ section.id }}"
        aria-expanded="false"
      >
        <span>PRODUCT DESCRIPTION</span>
        <svg class="pdp-chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <div class="collapse" id="pdp-desc-{{ section.id }}">
        <div class="pdp-accordion-body pdp-desc-body">
          {%- assign desc_text = product.description | strip_html | strip -%}
          {%- if desc_text != blank -%}
            {{ product.description }}
          {%- else -%}
            <p>No description available for this product.</p>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Care Instruction -->
    <div class="pdp-accordion">
      <button
        class="pdp-accordion-header"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#pdp-care-{{ section.id }}"
        aria-expanded="false"
      >
        <span>CARE INSTRUCTION</span>
        <svg class="pdp-chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <div class="collapse" id="pdp-care-{{ section.id }}">
        <div class="pdp-accordion-body">
          {%- if product.metafields.custom.care_instructions != blank -%}
            {{ product.metafields.custom.care_instructions }}
          {%- else -%}
            <p>{{ block.settings.care_instructions | default: 'Machine wash cold with like colors. Do not bleach. Tumble dry low. Iron on low heat if needed.' }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>

</div>
