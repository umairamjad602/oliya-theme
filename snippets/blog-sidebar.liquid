        <a class="img-content" href="{{ section.settings.insta_url3 }}">
          {%- if section.settings.insta_img3 != blank -%}
            {% assign image_height = section.settings.insta_img3.width
              | divided_by: section.settings.insta_img3.aspect_ratio
            %}
            {{
              section.settings.insta_img3
              | image_url: width: 300
              | image_tag:
                width: section.settings.insta_img3.width,
