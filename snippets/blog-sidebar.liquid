            }}
          {%- else -%}
            {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
            {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
          {%- endif -%}
        </a>
        <a class="img-content" href="{{ section.settings.insta_url5 }}">
          {%- if section.settings.insta_img5 != blank -%}
            {% assign image_height = section.settings.insta_img5.width
              | divided_by: section.settings.insta_img5.aspect_ratio
            %}
            {{
              section.settings.insta_img5
              | image_url: width: 300
              | image_tag:
                width: section.settings.insta_img5.width,
                height: image_height,
                class: 'lazyload',
                loading: 'lazy'
            }}
          {%- else -%}
            {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
            {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
          {%- endif -%}
        </a>
        <a class="img-content" href="{{ section.settings.insta_url6 }}">
          {%- if section.settings.insta_img6 != blank -%}
            {% assign image_height = section.settings.insta_img6.width
              | divided_by: section.settings.insta_img6.aspect_ratio
            %}
            {{
              section.settings.insta_img6
              | image_url: width: 300
              | image_tag:
                width: section.settings.insta_img6.width,
                height: image_height,
                class: 'lazyload',
                loading: 'lazy'
            }}
          {%- else -%}
            {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
            {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
          {%- endif -%}
        </a>
      </div>
    </div>
  {% endif %}
</div>
