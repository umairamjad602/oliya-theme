<div class="product-info">
  {% comment %}
    Renders product variant-picker

    Accepts:
    - product: {Object} product object.
    - block: {Object} passing the block information.
    - product_form_id: {String} Id of the product form to which the variant picker is associated.
    - update_url: {Boolean} whether or not to update url when changing variants. If false, the url isn't updated. Default: true (optional).
    Usage:
    {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
  {% endcomment %}
  {%- unless product.has_only_default_variant -%}
  {%- if block.settings.picker_type == 'button' -%}
    <pr-option
      id="variant-radios-{{ section.id }}"
      class="pr-option"
      data-section="{{ section.id }}"
      data-url="{{ product.url }}"
      {% if update_url == false %}
        data-update-url="false"
      {% endif %}
      {{ block.shopify_attributes }}
    >
      {%- for option in product.options_with_values -%}
        {%- liquid
          assign color_label = 'Color,color,colour,couleur,cor,colore,farbe,색,色,カラー,färg,farve,szín,barva' | split: ','
          assign swatch_count = option.values | map: 'swatch' | compact | size
          assign downcase_option = option.name | downcase
          assign is_color_option = false
          if color_label contains downcase_option
            assign is_color_option = true
          endif
          assign picker_type = block.settings.picker_type

          if block.settings.swatch_shape != 'none'
            if swatch_count > 0 or is_color_option
              if block.settings.picker_type == 'dropdown'
                assign picker_type = 'swatch_dropdown'
              else
                assign picker_type = 'swatch'
              endif
            endif
          endif
        -%}
        {%- if picker_type == 'swatch' -%}
          {%- assign swatch_config_pd = settings.color_swatch_config | newline_to_br | split: '<br />' -%}
          {%- assign _sv_parts = option.selected_value | split: ':' -%}
          {%- assign _sv_display = _sv_parts.first | strip -%}
          <varitem class="js variant-option-block product-form__input product-form__input--swatch">
            <h6 class="option-title">
              <span>{{ option.name }}:</span>
              <span class="current-option">{{ _sv_display }}</span>
            </h6>
            <div class="option-block">
              <div class="pd-inline-swatches{% if settings.show_swatch_color_name %} swatches-with-names{% endif %}">
                {%- for value in option.values -%}
                  {%- liquid
                    assign val_parts = value | split: ':'
                    assign display_name = val_parts.first | strip
                    assign val_lower = display_name | downcase | strip
                    assign pd_swatch_bg = ''
                    assign pd_swatch_is_solid = false

                    if val_parts.size > 1
                      assign inline_color = val_parts.last | strip
                      if inline_color contains '#' or inline_color contains 'rgb'
                        assign pd_swatch_bg = inline_color
                        assign pd_swatch_is_solid = true
                      endif
                    endif

                    if pd_swatch_bg == ''
                      for cfg_item in swatch_config_pd
                        assign cfg_parts = cfg_item | split: ':'
                        assign cfg_name  = cfg_parts.first | downcase | strip
                        assign cfg_val   = cfg_parts.last | strip
                        if val_lower == cfg_name
                          if cfg_val contains '#' or cfg_val contains 'rgb'
                            assign pd_swatch_bg = cfg_val
                            assign pd_swatch_is_solid = true
                          elsif cfg_val != blank
                            assign cfg_img = images[cfg_val] | image_url: width: 30
                            assign pd_swatch_bg = 'url(' | append: cfg_img | append: ') center/cover'
                          endif
                          break
                        endif
                      endfor

                      if value.swatch.image
                        assign sw_img = value.swatch.image | image_url: width: 30
                        assign pd_swatch_bg = 'url(' | append: sw_img | append: ') center/cover'
                        assign pd_swatch_is_solid = false
                      elsif value.swatch.color
                        assign pd_swatch_bg = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                        assign pd_swatch_is_solid = true
                      endif
                    endif

                    if pd_swatch_bg == ''
                      assign value_key = val_lower | replace: ' ', '-'
                      case value_key
                        when 'black', 'jet-black', 'jet', 'off-black', 'onyx'
                          assign pd_swatch_bg = '#111111'
                          assign pd_swatch_is_solid = true
                        when 'white', 'off-white', 'ivory', 'cream', 'snow'
                          assign pd_swatch_bg = '#FFFFFF'
                          assign pd_swatch_is_solid = true
                        when 'red', 'bright-red', 'cherry-red', 'scarlet', 'cherry', 'tomato'
                          assign pd_swatch_bg = '#D32F2F'
                          assign pd_swatch_is_solid = true
                        when 'dark-red', 'wine', 'maroon', 'burgundy', 'oxblood'
                          assign pd_swatch_bg = '#7B1A1A'
                          assign pd_swatch_is_solid = true
                        when 'pink', 'hot-pink', 'fuchsia', 'magenta'
                          assign pd_swatch_bg = '#E91E8C'
                          assign pd_swatch_is_solid = true
                        when 'light-pink', 'baby-pink', 'powder-pink', 'pastel-pink', 'soft-pink'
                          assign pd_swatch_bg = '#FFCDD2'
                          assign pd_swatch_is_solid = true
                        when 'blush', 'blush-pink', 'blush-rose'
                          assign pd_swatch_bg = '#F4B8C1'
                          assign pd_swatch_is_solid = true
                        when 'rose', 'dusty-rose', 'vintage-rose'
                          assign pd_swatch_bg = '#C48B9F'
                          assign pd_swatch_is_solid = true
                        when 'mauve', 'dusty-mauve', 'dusty-pink'
                          assign pd_swatch_bg = '#B5737B'
                          assign pd_swatch_is_solid = true
                        when 'coral', 'peach-coral'
                          assign pd_swatch_bg = '#FF6B6B'
                          assign pd_swatch_is_solid = true
                        when 'peach', 'apricot'
                          assign pd_swatch_bg = '#FFCC99'
                          assign pd_swatch_is_solid = true
                        when 'salmon'
                          assign pd_swatch_bg = '#FA8072'
                          assign pd_swatch_is_solid = true
                        when 'orange', 'tangerine', 'burnt-orange', 'amber'
                          assign pd_swatch_bg = '#F57C00'
                          assign pd_swatch_is_solid = true
                        when 'yellow', 'lemon', 'bright-yellow', 'sunshine'
                          assign pd_swatch_bg = '#FDD835'
                          assign pd_swatch_is_solid = true
                        when 'gold', 'mustard', 'mustard-yellow', 'golden', 'honey'
                          assign pd_swatch_bg = '#F9A825'
                          assign pd_swatch_is_solid = true
                        when 'green', 'forest-green', 'dark-green', 'bottle-green'
                          assign pd_swatch_bg = '#2E7D32'
                          assign pd_swatch_is_solid = true
                        when 'light-green', 'lime', 'lime-green', 'apple-green'
                          assign pd_swatch_bg = '#8BC34A'
                          assign pd_swatch_is_solid = true
                        when 'mint', 'mint-green', 'spearmint'
                          assign pd_swatch_bg = '#A5D6A7'
                          assign pd_swatch_is_solid = true
                        when 'sage', 'sage-green', 'eucalyptus'
                          assign pd_swatch_bg = '#87A878'
                          assign pd_swatch_is_solid = true
                        when 'olive', 'army-green', 'military-green', 'khaki-green'
                          assign pd_swatch_bg = '#6D6928'
                          assign pd_swatch_is_solid = true
                        when 'teal', 'dark-teal'
                          assign pd_swatch_bg = '#00796B'
                          assign pd_swatch_is_solid = true
                        when 'emerald', 'emerald-green'
                          assign pd_swatch_bg = '#00695C'
                          assign pd_swatch_is_solid = true
                        when 'blue', 'royal-blue', 'cobalt', 'bright-blue'
                          assign pd_swatch_bg = '#1976D2'
                          assign pd_swatch_is_solid = true
                        when 'light-blue', 'sky-blue', 'baby-blue', 'powder-blue', 'pale-blue'
                          assign pd_swatch_bg = '#90CAF9'
                          assign pd_swatch_is_solid = true
                        when 'navy', 'navy-blue', 'dark-navy', 'midnight-blue', 'midnight', 'midnight-navy'
                          assign pd_swatch_bg = '#0D1B3E'
                          assign pd_swatch_is_solid = true
                        when 'denim', 'chambray', 'steel-blue'
                          assign pd_swatch_bg = '#5C7EA8'
                          assign pd_swatch_is_solid = true
                        when 'turquoise', 'aqua', 'cyan', 'aqua-blue'
                          assign pd_swatch_bg = '#00BCD4'
                          assign pd_swatch_is_solid = true
                        when 'purple', 'violet', 'plum', 'grape'
                          assign pd_swatch_bg = '#7B1FA2'
                          assign pd_swatch_is_solid = true
                        when 'dark-purple', 'deep-purple', 'eggplant'
                          assign pd_swatch_bg = '#4A148C'
                          assign pd_swatch_is_solid = true
                        when 'lavender', 'lilac', 'wisteria'
                          assign pd_swatch_bg = '#CE93D8'
                          assign pd_swatch_is_solid = true
                        when 'gray', 'grey', 'charcoal', 'dark-gray', 'dark-grey', 'slate'
                          assign pd_swatch_bg = '#616161'
                          assign pd_swatch_is_solid = true
                        when 'light-gray', 'light-grey', 'silver', 'ash', 'heather', 'stone'
                          assign pd_swatch_bg = '#BDBDBD'
                          assign pd_swatch_is_solid = true
                        when 'brown', 'chocolate', 'coffee', 'mocha', 'espresso', 'cocoa'
                          assign pd_swatch_bg = '#5D4037'
                          assign pd_swatch_is_solid = true
                        when 'tan', 'camel', 'sand', 'desert', 'latte'
                          assign pd_swatch_bg = '#C8A882'
                          assign pd_swatch_is_solid = true
                        when 'beige', 'natural', 'nude', 'khaki', 'wheat'
                          assign pd_swatch_bg = '#D7CCC8'
                          assign pd_swatch_is_solid = true
                        when 'leopard', 'animal', 'animal-print', 'cheetah'
                          assign pd_swatch_bg = 'repeating-linear-gradient(45deg,#C9A84C,#C9A84C 4px,#3B2A00 4px,#3B2A00 8px)'
                        when 'stripe', 'stripes', 'striped'
                          assign pd_swatch_bg = 'repeating-linear-gradient(90deg,#444 0,#444 4px,#fff 4px,#fff 8px)'
                        else
                          assign pd_swatch_bg = val_lower | replace: ' ', ''
                      endcase
                    endif

                    assign pd_input_id = section.id | append: '-pd-' | append: option.position | append: '-' | append: forloop.index0
                    assign pd_checked = false
                    if option.selected_value == value
                      assign pd_checked = true
                    endif
                  -%}
                  <label
                    for="{{ pd_input_id }}"
                    class="pd-swatch-label{% if pd_checked %} active-swatch{% endif %}{% if settings.show_swatch_color_name %} has-swatch-name{% endif %}"
                    title="{{ display_name }}"
                  >
                    <input
                      type="radio"
                      id="{{ pd_input_id }}"
                      name="{{ option.name }}"
                      value="{{ value | escape }}"
                      form="{{ product_form_id }}"
                      class="swatch-input__input visually-hidden"
                      {% if pd_checked %}checked{% endif %}
                    >
                    <span class="inline-swatch" style="background: {{ pd_swatch_bg }};"></span>
                    {%- if settings.show_swatch_color_name -%}
                      <span class="swatch-name-label"{% if pd_swatch_is_solid %} style="color:{{ pd_swatch_bg }}"{% endif %}>{{ display_name }}</span>
                    {%- endif -%}
                  </label>
                {%- endfor -%}
              </div>
            </div>
          </varitem>
        {%- elsif picker_type == 'button' -%}
          <varitem class="js variant-option-block product-form__input product-form__input--pill">
            <h6 class="option-title">
              <span>{{ option.name }}:</span>
              <span class="current-option">{{ option.selected_value }}</span>
            </h6>
            <div class="option-block">
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: picker_type
              %}
            </div>
          </varitem>
        {%- endif -%}
      {%- endfor -%}
      <script type="application/json">
        {{ product.variants | json }}
      </script>
    </pr-option>
    {% else %}
    <selects-box
    id="variant-selects-{{ section.id }}"
    class="pr-option"
    data-section="{{ section.id }}"
    data-url="{{ product.url }}"
    {% if update_url == false %}
      data-update-url="false"
    {% endif %}
    {{ block.shopify_attributes }}>
    {%- for option in product.options_with_values -%}
    <div class="variant-option-block ">
      <h6 class="option-title" for="Option-{{ section.id }}-{{ forloop.index0 }}">
        {{ option.name }}:
        <span class="current-option" id="current-option{{ forloop.index0 }}">{{ option.selected_value }}</span>
      </h6>
        <div class="option-block">
          <select
            id="Option-{{ section.id }}-{{ forloop.index0 }}"
          class="select__select"
          name="options[{{ option.name | escape }}]"
          form="{{ product_form_id }}"
          onchange="Option{{ forloop.index0 }}()"
          >
            {% render 'product-variant-options',
              product: product,
              option: option,
              block: block,
              picker_type: picker_type
            %}
          </select>
        </div>
      </div>
      <script type="text/javascript">
        function Option{{ forloop.index0 }}() {
          var newColor = document.getElementById('Option-{{ section.id }}-{{ forloop.index0 }}').value;
          document.getElementById("current-option{{ forloop.index0 }}").innerHTML = newColor;
        }
      </script>
      {%- endfor -%}
      <script type="application/json">
      {{ product.variants | json }}
    </script>
    </selects-box>
    {% endif %}
  {%- endunless -%}
  <noscript class="pro-form-noscript-{{ section.id }}">
    <div class="variant-option-block {% if product.has_only_default_variant %} hidden{% endif %}">
      <h6 class="option-title" for="Variants-{{ section.id }}">
        {{- 'products.product.product_variants' | t -}}
      </h6>
      <div class="option-block">
        <select
          name="id"
          id="Variants-{{ section.id }}"
          class="select__select"
          form="{{ product_form_id }}">
          {%- for variant in product.variants -%}
            <option
              {% if variant == product.selected_or_first_available_variant %}
                selected="selected"
              {% endif %}
              {% if variant.available == false %}
                disabled
              {% endif %}
              value="{{ variant.id }}">
              {%- liquid
                echo variant.title
                echo variant.price | money | strip_html | prepend: ' - '
                if variant.available == false
                  echo 'products.product.sold_out' | t | prepend: ' - '
                endif
                if variant.quantity_rule.increment > 1
                  echo 'products.product.quantity.multiples_of' | t: quantity: variant.quantity_rule.increment | prepend: ' - '
                endif
                if variant.quantity_rule.min > 1
                  echo 'products.product.quantity.minimum_of' | t: quantity: variant.quantity_rule.min | prepend: ' - '
                endif
                if variant.quantity_rule.max != null
                  echo 'products.product.quantity.maximum_of' | t: quantity: variant.quantity_rule.max | prepend: ' - '
                endif
                assign cart_quantity = cart | item_count_for_variant: variant.id
                if cart_quantity > 0
                  echo 'products.product.quantity.in_cart_html' | t: quantity: cart_quantity | prepend: ' - '
                endif
              -%}
            </option>
          {%- endfor -%}
        </select>
      </div>
    </div>
  </noscript>
</div>