{%- liquid
  assign bc_height = settings.breadcrumb_height | default: 300
  assign has_uploaded = settings.breadcrumb_bgimg != blank
  assign has_external  = settings.breadcrumb_external_image_url != blank
  assign show_image    = settings.breadcrumb_bgimg_enable and (has_uploaded or has_external)
-%}

<section
  class="breadcrumb-area"
  style="
    --bc-height: {{ bc_height }}px;
    --bc-overlay: {{ settings.breadcrumb_bgimg_overlay_color | default: '#000000' }};
    --bc-overlay-opacity: {{ settings.breadcrumb_bgimg_overlay_color_opacity | default: 0.45 }};
    --bc-title-color: {{ settings.breadcrumb_main_title_color | default: '#ffffff' }};
    --bc-link-color: {{ settings.breadcrumb_title_color | default: '#ffffff' }};
    {% if settings.breadcrumb_bgcolor_enable and show_image == false %}background-color: {{ settings.breadcrumb_bgcolor | default: '#1a1a1a' }};{% endif %}
  "
>
  {%- if show_image -%}
    <div class="bc-img-wrap">
      {%- if has_uploaded -%}
        {{
          settings.breadcrumb_bgimg
          | image_url: width: 1920
          | image_tag:
            loading: 'lazy',
            class: 'bc-bg-img',
            width: 1920,
            height: bc_height,
            alt: settings.breadcrumb_bgimg.alt
        }}
      {%- else -%}
        <img
          src="{{ settings.breadcrumb_external_image_url }}"
          class="bc-bg-img"
          loading="lazy"
          width="1920"
          height="{{ bc_height }}"
          alt=""
        >
      {%- endif -%}
      {%- if settings.breadcrumb_bgimg_overlay_color_enable -%}
        <div class="bc-overlay"></div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="container">
    <div class="breadcrumb-index">
      {% render 'breadcrumb-builtin' %}
      <div class="breadcrumb-title">
        {% if template contains 'product' %}
          <h1 class="mr-0">{{ product.title }}</h1>
        {% elsif template contains 'collection' and collection.handle %}
          <h1 class="mr-0">{{ collection.title }}</h1>
        {% elsif template == 'blog' %}
          <h1 class="mr-0">{{ blog.title }}</h1>
        {% elsif template == 'article' %}
          <h1 class="mr-0">{{ blog.title }}</h1>
        {% else %}
          <h1 class="mr-0">{{ page_title }}</h1>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.breadcrumb-area {
  position: relative;
  display: flex;
  align-items: center;
  min-height: var(--bc-height);
  padding: 24px 0;
  overflow: hidden;
}

.breadcrumb-area .bc-img-wrap {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.breadcrumb-area .bc-bg-img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.breadcrumb-area .bc-overlay {
  position: absolute;
  inset: 0;
  background-color: var(--bc-overlay);
  opacity: var(--bc-overlay-opacity);
  pointer-events: none;
}

.breadcrumb-area .container {
  position: relative;
  z-index: 1;
  width: 100%;
}

.breadcrumb-area .breadcrumb-index {
  text-align: center;
}

.breadcrumb-area .breadcrumb-title {
  margin-top: 8px;
}

.breadcrumb-area .breadcrumb-title h1 {
  color: var(--bc-title-color);
  font-size: 40px;
  line-height: 1.2;
  margin: 0;
}

/* breadcrumb nav links inherit link colour */
.breadcrumb-area .breadcrumb-builtin,
.breadcrumb-area .breadcrumb-builtin a,
.breadcrumb-area .breadcrumb-builtin span {
  color: var(--bc-link-color);
}

@media (max-width: 1199px) {
  .breadcrumb-area .breadcrumb-title h1 { font-size: 30px; }
}
@media (max-width: 767px) {
  .breadcrumb-area { min-height: calc(var(--bc-height) * 0.75); }
  .breadcrumb-area .breadcrumb-title h1 { font-size: 24px; }
}
@media (max-width: 479px) {
  .breadcrumb-area .breadcrumb-title h1 { font-size: 20px; }
}
</style>
