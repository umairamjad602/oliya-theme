{%- liquid
  assign bc_height = settings.breadcrumb_height | default: 300

  # Pick the image URL based on current template/page
  assign bc_img = settings.breadcrumb_img_default

  if template contains 'collection'
    assign bc_img = settings.breadcrumb_img_collection
  elsif template == 'list-collections'
    assign bc_img = settings.breadcrumb_img_collection
  elsif template == 'blog'
    assign bc_img = settings.breadcrumb_img_blog
  elsif template == 'article'
    assign bc_img = settings.breadcrumb_img_article
  elsif template == 'search'
    assign bc_img = settings.breadcrumb_img_search
  elsif template == 'cart'
    assign bc_img = settings.breadcrumb_img_cart
  elsif template.name == 'page'
    assign suffix = template.suffix | downcase
    if suffix contains 'faq'
      assign bc_img = settings.breadcrumb_img_faq
    elsif suffix contains 'about'
      assign bc_img = settings.breadcrumb_img_about
    elsif suffix contains 'contact'
      assign bc_img = settings.breadcrumb_img_contact
    elsif suffix contains 'shipping' or suffix contains 'return' or suffix contains 'refund'
      assign bc_img = settings.breadcrumb_img_shipping
    elsif suffix contains 'privacy'
      assign bc_img = settings.breadcrumb_img_privacy
    elsif suffix contains 'term'
      assign bc_img = settings.breadcrumb_img_terms
    endif
  endif

  # Fallback to default if page-specific URL is blank
  if bc_img == blank
    assign bc_img = settings.breadcrumb_img_default
  endif

  assign show_image = settings.breadcrumb_bgimg_enable and bc_img != blank
-%}

<section
  class="breadcrumb-area"
  style="
    --bc-height: {{ bc_height }}px;
    --bc-overlay: {{ settings.breadcrumb_bgimg_overlay_color | default: '#000000' }};
    --bc-overlay-opacity: {{ settings.breadcrumb_bgimg_overlay_color_opacity | default: 0.5 }};
    --bc-title-color: {{ settings.breadcrumb_main_title_color | default: '#ffffff' }};
    --bc-link-color: {{ settings.breadcrumb_title_color | default: '#ffffff' }};
    {% unless show_image %}background-color: {{ settings.breadcrumb_bgcolor | default: '#1a1a1a' }};{% endunless %}
  "
>
  {%- if show_image -%}
    <div class="bc-img-wrap">
      <img
        src="{{ bc_img }}"
        class="bc-bg-img"
        loading="lazy"
        width="1920"
        height="{{ bc_height }}"
        alt=""
      >
      {%- if settings.breadcrumb_bgimg_overlay_color_enable -%}
        <div class="bc-overlay"></div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="container">
    <div class="breadcrumb-index">
      {% render 'breadcrumb-builtin' %}
      <div class="breadcrumb-title">
        {% if template contains 'product' %}
          <h1 class="mr-0">{{ product.title }}</h1>
        {% elsif template contains 'collection' and collection.handle %}
          <h1 class="mr-0">{{ collection.title }}</h1>
        {% elsif template == 'blog' %}
          <h1 class="mr-0">{{ blog.title }}</h1>
        {% elsif template == 'article' %}
          <h1 class="mr-0">{{ blog.title }}</h1>
        {% else %}
          <h1 class="mr-0">{{ page_title }}</h1>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.breadcrumb-area {
  position: relative;
  display: flex;
  align-items: center;
  min-height: var(--bc-height);
  padding: 24px 0;
  overflow: hidden;
}
.breadcrumb-area .bc-img-wrap {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.breadcrumb-area .bc-bg-img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.breadcrumb-area .bc-overlay {
  position: absolute;
  inset: 0;
  background-color: var(--bc-overlay);
  opacity: var(--bc-overlay-opacity);
  pointer-events: none;
}
.breadcrumb-area .container {
  position: relative;
  z-index: 1;
  width: 100%;
}
.breadcrumb-area .breadcrumb-index {
  text-align: center;
}
.breadcrumb-area .breadcrumb-title {
  margin-top: 8px;
}
.breadcrumb-area .breadcrumb-title h1 {
  color: var(--bc-title-color);
  font-size: 40px;
  line-height: 1.2;
  margin: 0;
}
.breadcrumb-area .breadcrumb-builtin,
.breadcrumb-area .breadcrumb-builtin a,
.breadcrumb-area .breadcrumb-builtin span {
  color: var(--bc-link-color);
}
@media (max-width: 1199px) {
  .breadcrumb-area .breadcrumb-title h1 { font-size: 30px; }
}
@media (max-width: 767px) {
  .breadcrumb-area { min-height: calc(var(--bc-height) * 0.75); }
  .breadcrumb-area .breadcrumb-title h1 { font-size: 24px; }
}
@media (max-width: 479px) {
  .breadcrumb-area .breadcrumb-title h1 { font-size: 20px; }
}
</style>
