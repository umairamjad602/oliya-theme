<div class="product-info" {{ block.shopify_attributes }}>
  {%- assign color_label = 'Color,color,colour,couleur,cor,colore,farbe,색,色,カラー,färg,farve,szín,barva'
    | split: ','
  -%}
  {%- unless product.has_only_default_variant -%}
    {%- if block.settings.picker_type == 'button' -%}
      <pr-option
        id="variant-radios-{{ section.id }}"
        class="pr-option"
        data-section="{{ section.id }}"
        data-url="{{ product.url }}"
        {% if update_url == false %}
          data-update-url="false"
        {% endif %}
        {{ block.shopify_attributes }}
      >
        {%- for option in product.options_with_values -%}
          {%- liquid
            assign is_color = false
            assign downcase_option = option.name | downcase
            if color_label contains downcase_option
              assign is_color = true
            endif
          -%}
          <varitem class="js variant-option-block">
            <h6 class="mr-0 option-title">
              <span>{{ option.name }}:</span>
              <span class="current-option">{{ option.selected_value }}</span>
            </h6>
            <div class="option-block">
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                color_label: color_label,
                downcase_option: downcase_option,
                is_color: is_color
              %}
            </div>
          </varitem>
        {%- endfor -%}
        <script type="application/json">
          {{ product.variants | json }}
        </script>
      </pr-option>
    {%- else -%}
      <selects-box
        id="variant-selects-{{ section.id }}"
        class="pr-option"
        data-section="{{ section.id }}"
        data-url="{{ product.url }}"
        {% if update_url == false %}
          data-update-url="false"
        {% endif %}
        {{ block.shopify_attributes }}
      >
        {%- for option in product.options_with_values -%}
          <div class="variant-option-block ">
            <h6 class="mr-0 option-title" for="Option-{{ section.id }}-{{ forloop.index0 }}">
              {{ option.name }}:
              <span class="current-option" id="current-option{{ forloop.index0 }}">{{ option.selected_value }}</span>
            </h6>
            <div class="option-block">
              <select
                id="Option-{{ section.id }}-{{ forloop.index0 }}"
                class="select__select"
                name="options[{{ option.name | escape }}]"
                form="{{ product_form_id }}"
                onchange="Option{{ forloop.index0 }}()"
              >
                {% render 'product-variant-options', product: product, option: option, block: block %}
              </select>
            </div>
          </div>
          <script type="text/javascript">
            function Option{{ forloop.index0 }}() {
              var newColor = document.getElementById('Option-{{ section.id }}-{{ forloop.index0 }}').value;
              document.getElementById("current-option{{ forloop.index0 }}").innerHTML = newColor;
            }
          </script>
        {%- endfor -%}
        <script type="application/json">
          {{ product.variants | json }}
        </script>
      </selects-box>
    {%- endif -%}
  {%- endunless -%}
  <noscript class="pro-form-noscript-{{ section.id }}">
    <div class="variant-option-block {% if product.has_only_default_variant %} hidden{% endif %}">
      <h6 class="mr-0 option-title" for="Variants-{{ section.id }}">
        {{- 'products.product.product_variants' | t -}}
      </h6>
      <div class="select">
        <select
          name="id"
          id="Variants-{{ section.id }}"
          class="select__select"
          form="{{ product_form_id }}"
        >
          {%- for variant in product.variants -%}
            <option
              {% if variant == product.selected_or_first_available_variant %}
                selected="selected"
              {% endif %}
              {% if variant.available == false %}
                disabled
              {% endif %}
              value="{{ variant.id }}"
            >
              {%- liquid
                echo variant.title
                echo variant.price | money | strip_html | prepend: ' - '
                if variant.available == false
                  echo 'products.product.sold_out' | t | prepend: ' - '
                endif
                if variant.quantity_rule.increment > 1
                  echo 'products.product.quantity.multiples_of' | t: quantity: variant.quantity_rule.increment | prepend: ' - '
                endif
                if variant.quantity_rule.min > 1
                  echo 'products.product.quantity.minimum_of' | t: quantity: variant.quantity_rule.min | prepend: ' - '
                endif
                if variant.quantity_rule.max != null
                  echo 'products.product.quantity.maximum_of' | t: quantity: variant.quantity_rule.max | prepend: ' - '
                endif
                assign cart_quantity = cart | item_count_for_variant: variant.id
                if cart_quantity > 0
                  echo 'products.product.quantity.in_cart_html' | t: quantity: cart_quantity | prepend: ' - '
                endif
              -%}
            </option>
          {%- endfor -%}
        </select>
      </div>
    </div>
  </noscript>
</div>