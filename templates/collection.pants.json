{
  "sections": {
    "collection-banner": {
      "type": "collection-banner",
      "settings": {
        "banner_height": 460,
        "overlay_opacity": 40,
        "text_align": "center",
        "show_description": true,
        "show_product_count": false
      }
    },
    "collection-template": {
      "type": "collection-template",
      "settings": {
        "container": "normal",
        "section_background_color": "#f8f7f3",
        "product_view": "grid-5",
        "product_view_lg": "grid-lg-3",
        "product_view_sm": "grid-sm-2",
        "tab_bar_enable": true,
        "short_by_enable": true
      }
    }
  },
  "order": [
    "collection-banner",
    "collection-template"
  ]
}
