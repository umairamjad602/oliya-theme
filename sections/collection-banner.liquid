{%- comment -%}
  Priority: 1) collection metafield (custom.cover_image) — set per-collection in Shopify Admin
             2) collection.image — the main image on the collection in Shopify Admin
             3) placeholder SVG
{%- endcomment -%}

{%- assign meta_cover = collection.metafields.custom.cover_image.value -%}
{%- assign banner_title = section.settings.custom_title | default: collection.title -%}
{%- assign banner_desc  = section.settings.custom_description | default: collection.description -%}

<section
  class="collection-banner-section"
  style="--cb-height: {{ section.settings.banner_height }}px; --cb-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>
  <div class="cb-wrap">

    {%- if meta_cover != blank -%}
      {{
        meta_cover
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          class: 'cb-img',
          alt: meta_cover.alt | default: banner_title
      }}
    {%- elsif collection.image != blank -%}
      {{
        collection.image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          class: 'cb-img',
          alt: collection.image.alt | default: banner_title
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'cb-placeholder' }}
    {%- endif -%}

    <div class="cb-overlay"></div>

    <div class="container cb-inner">
      <div class="cb-text cb-align-{{ section.settings.text_align }}">
        {%- if banner_title != blank -%}
          <h1 class="cb-title">{{ banner_title }}</h1>
        {%- endif -%}
        {%- if section.settings.show_description and banner_desc != blank -%}
          <p class="cb-desc">{{ banner_desc | strip_html }}</p>
        {%- endif -%}
        {%- if section.settings.show_product_count -%}
          <p class="cb-count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</p>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Collection Banner",
  "settings": [
    {
      "type": "header",
      "content": "Cover image"
    },
    {
      "type": "paragraph",
      "content": "Upload a cover image per-collection: go to Shopify Admin → Settings → Custom data → Collections → Add definition. Set Namespace = custom, Key = cover_image, Type = File (image). Then open any collection and upload its cover image in the Metafields section at the bottom of the page."
    },
    {
      "type": "header",
      "content": "Text overrides"
    },
    {
      "type": "paragraph",
      "content": "Leave blank to auto-use the collection title and description."
    },
    {
      "type": "text",
      "id": "custom_title",
      "label": "Custom title"
    },
    {
      "type": "textarea",
      "id": "custom_description",
      "label": "Custom description"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner height",
      "min": 200,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 460
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "label": "Left",   "value": "left"   },
        { "label": "Center", "value": "center" },
        { "label": "Right",  "value": "right"  }
      ],
      "default": "center"
    }
  ],
  "presets": [
    { "name": "Collection Banner" }
  ]
}
{% endschema %}

<style>
.collection-banner-section .cb-wrap {
  position: relative;
  width: 100%;
  height: var(--cb-height, 460px);
  overflow: hidden;
  display: flex;
  align-items: center;
}
.collection-banner-section .cb-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}
.collection-banner-section .cb-placeholder {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.collection-banner-section .cb-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, var(--cb-overlay, 0.4));
  pointer-events: none;
}
.collection-banner-section .cb-inner {
  position: relative;
  z-index: 1;
  width: 100%;
}
.collection-banner-section .cb-text {
  max-width: 700px;
}
.collection-banner-section .cb-align-center {
  text-align: center;
  margin: 0 auto;
}
.collection-banner-section .cb-align-left {
  text-align: left;
}
.collection-banner-section .cb-align-right {
  text-align: right;
  margin-left: auto;
}
.collection-banner-section .cb-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', Georgia, serif);
  font-size: clamp(32px, 5vw, 64px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: 0.02em;
  color: #ffffff;
  margin: 0 0 14px;
  text-shadow: 0 2px 12px rgba(0,0,0,0.25);
}
.collection-banner-section .cb-desc {
  font-size: 16px;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.88);
  margin: 0 0 10px;
}
.collection-banner-section .cb-count {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.65);
  margin: 10px 0 0;
}

@media (max-width: 991px) {
  .collection-banner-section .cb-title { font-size: clamp(26px, 4vw, 44px); }
}
@media (max-width: 767px) {
  .collection-banner-section .cb-title { font-size: 28px; margin-bottom: 10px; }
  .collection-banner-section .cb-desc  { font-size: 14px; }
}
@media (max-width: 479px) {
  .collection-banner-section .cb-title { font-size: 22px; }
  .collection-banner-section .cb-desc  { font-size: 13px; }
}
</style>
