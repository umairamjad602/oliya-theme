{{ 'collection-list.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'swiper-bundle.css' | asset_url }}">

<section
  class="collection-list"
  style="
    --padding-top: {{ section.settings.section_padding_top }}px;
    --padding-bottom: {{ section.settings.section_padding_bottom }}px;
    --padding-top-ipad: {{ section.settings.section_padding_top_ipad }}px;
    --padding-bottom-ipad: {{ section.settings.section_padding_bottom_ipad }}px;
    --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;
    --padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;
    --background-color: {{ section.settings.section_bg_color }};
  "
>

  {%- comment -%} Header row (heading + nav arrows) {%- endcomment -%}
  <div class="cl-header-row">
    <div class="cl-header-left">
      {%- if section.settings.section_subheading != blank -%}
        <p class="cl-subheading">{{ section.settings.section_subheading }}</p>
      {%- endif -%}
      {%- if section.settings.section_heading != blank -%}
        <h2 class="cl-heading">{{ section.settings.section_heading }}</h2>
      {%- endif -%}
    </div>

    <div class="cl-header-right">
      {%- if section.settings.view_all_url != blank -%}
        <a href="{{ section.settings.view_all_url }}" class="cl-view-all">
          {{ section.settings.view_all_label | default: 'Shop All' }} &rarr;
        </a>
      {%- endif -%}
      <div class="cl-nav">
        <button class="cl-nav-btn cl-prev" type="button" aria-label="Previous collection">
          <i class="feather-arrow-left"></i>
        </button>
        <span class="cl-nav-divider"></span>
        <button class="cl-nav-btn cl-next" type="button" aria-label="Next collection">
          <i class="feather-arrow-right"></i>
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} Full-width Swiper {%- endcomment -%}
  <div class="cl-slider-outer">
    <div class="swiper cl-swiper" id="cl-swiper-{{ section.id }}">
      <div class="swiper-wrapper">

        {%- if section.settings.show_all_collections -%}
          {%- for c in collections -%}
            <div class="swiper-slide cl-item">
              <a href="{{ c.url }}" class="cl-card">
                <div class="cl-img">
                  {%- if c.image != blank -%}
                    {{
                      c.image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        alt: c.image.alt | default: c.title
                    }}
                  {%- else -%}
                    {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                    {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
                <div class="cl-overlay">
                  <div class="cl-card-info">
                    <h6 class="cl-title">{{ c.title }}</h6>
                    {%- if section.settings.cat_button != blank -%}
                      <span class="cl-shop-btn">{{ section.settings.cat_button }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </div>
          {%- endfor -%}

        {%- else -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'slider_cat' -%}
                {%- assign col = collections[block.settings.slider_category_handle] -%}
                <div class="swiper-slide cl-item" {{ block.shopify_attributes }}>
                  <a href="{{ col.url }}" class="cl-card">
                    <div class="cl-img">
                      {%- if block.settings.cat_img != blank -%}
                        {{
                          block.settings.cat_img
                          | image_url: width: 600
                          | image_tag:
                            loading: 'lazy',
                            alt: block.settings.cat_img.alt
                        }}
                      {%- elsif col.image != blank -%}
                        {{
                          col.image
                          | image_url: width: 600
                          | image_tag:
                            loading: 'lazy',
                            alt: col.image.alt | default: col.title
                        }}
                      {%- else -%}
                        {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                        {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                    <div class="cl-overlay">
                      <div class="cl-card-info">
                        <h6 class="cl-title">
                          {{ block.settings.cat_custom_title | default: col.title | default: 'Collection' }}
                        </h6>
                        {%- if block.settings.cat_description != blank -%}
                          <p class="cl-desc">{{ block.settings.cat_description }}</p>
                        {%- endif -%}
                        {%- if section.settings.cat_button != blank -%}
                          <span class="cl-shop-btn">{{ section.settings.cat_button }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                  </a>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        {%- endif -%}

      </div>
    </div>
  </div>

</section>

<script src="{{ 'swiper-bundle.js' | asset_url }}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('#cl-swiper-{{ section.id }}', {
      slidesPerView: 5,
      spaceBetween: 2,
      loop: false,
      navigation: {
        nextEl: '.cl-next',
        prevEl: '.cl-prev',
      },
      breakpoints: {
        0:    { slidesPerView: 1.5, spaceBetween: 8 },
        480:  { slidesPerView: 2.2, spaceBetween: 10 },
        768:  { slidesPerView: 3,   spaceBetween: 2 },
        1024: { slidesPerView: 4,   spaceBetween: 2 },
        1280: { slidesPerView: 5,   spaceBetween: 2 },
      },
    });
  });
</script>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "paragraph",
      "content": "Tablet"
    },
    {
      "type": "range",
      "id": "section_padding_top_ipad",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom_ipad",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "section_subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link URL"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all link text",
      "default": "Shop All"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "text",
      "id": "cat_button",
      "label": "Shop button text",
      "default": "Shop Now"
    },
    {
      "type": "checkbox",
      "id": "show_all_collections",
      "label": "Show all collections automatically",
      "info": "Displays all store collections instead of manually selected blocks.",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slider_cat",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "slider_category_handle",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "cat_img",
          "label": "Custom image",
          "info": "Recommended size: 480x720px (2:3 portrait)"
        },
        {
          "type": "text",
          "id": "cat_custom_title",
          "label": "Custom title (overrides collection name)"
        },
        {
          "type": "textarea",
          "id": "cat_description",
          "label": "Description (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "slider_cat" },
        { "type": "slider_cat" },
        { "type": "slider_cat" },
        { "type": "slider_cat" },
        { "type": "slider_cat" }
      ]
    }
  ]
}
{% endschema %}
