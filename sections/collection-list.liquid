{{ 'collection-list.css' | asset_url | stylesheet_tag }}
<section
  class="collection-list"
  style="--padding-top: {{ section.settings.section_padding_top }}px; --padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-ipad: {{ section.settings.section_padding_top_ipad }}px; --padding-bottom-ipad: {{ section.settings.section_padding_bottom_ipad }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px; --padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px; --background-color: {{ section.settings.section_bg_color }};"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid{% else %}container{% endif %}">

    {%- if section.settings.section_heading != blank or section.settings.section_subheading != blank or section.settings.view_all_url != blank -%}
      <div class="cl-header">
        <div class="cl-header-left">
          {%- if section.settings.section_subheading != blank -%}
            <p class="cl-subheading">{{ section.settings.section_subheading }}</p>
          {%- endif -%}
          {%- if section.settings.section_heading != blank -%}
            <h2 class="cl-heading" data-fade-in>{{ section.settings.section_heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.view_all_url != blank -%}
          <a href="{{ section.settings.view_all_url }}" class="cl-view-all">
            {{ section.settings.view_all_label | default: 'Shop All' }} &rarr;
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="cl-grid">

      {%- if section.settings.show_all_collections -%}
        {%- for c in collections -%}
          <div class="cl-item">
            <a href="{{ c.url }}" class="cl-card">
              <div class="cl-img">
                {%- if c.image != blank -%}
                  {{
                    c.image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      width: c.image.width,
                      height: c.image.height,
                      class: 'lazyload',
                      alt: c.image.alt | default: c.title
                    | escape
                  }}
                {%- else -%}
                  {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                  {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="cl-overlay">
                <div class="cl-card-info">
                  <h6 class="cl-title">{{ c.title }}</h6>
                  {%- if section.settings.cat_button != blank -%}
                    <span class="cl-shop-btn">{{ section.settings.cat_button }}</span>
                  {%- endif -%}
                </div>
              </div>
            </a>
          </div>
        {%- endfor -%}

      {%- else -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'slider_cat' -%}
              {%- assign col = collections[block.settings.slider_category_handle] -%}
              <div class="cl-item" {{ block.shopify_attributes }}>
                <a href="{{ col.url }}" class="cl-card">
                  <div class="cl-img">
                    {%- if block.settings.cat_img != blank -%}
                      {{
                        block.settings.cat_img
                        | image_url: width: 600
                        | image_tag:
                          loading: 'lazy',
                          width: block.settings.cat_img.width,
                          height: block.settings.cat_img.height,
                          class: 'lazyload',
                          alt: block.settings.cat_img.alt
                        | escape
                      }}
                    {%- elsif col.image != blank -%}
                      {{
                        col.image
                        | image_url: width: 600
                        | image_tag:
                          loading: 'lazy',
                          width: col.image.width,
                          height: col.image.height,
                          class: 'lazyload',
                          alt: col.image.alt | default: col.title
                        | escape
                      }}
                    {%- else -%}
                      {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                      {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <div class="cl-overlay">
                    <div class="cl-card-info">
                      <h6 class="cl-title">{{ block.settings.cat_custom_title | default: col.title | default: 'Collection' }}</h6>
                      {%- if block.settings.cat_description != blank -%}
                        <p class="cl-desc">{{ block.settings.cat_description }}</p>
                      {%- endif -%}
                      {%- if section.settings.cat_button != blank -%}
                        <span class="cl-shop-btn">{{ section.settings.cat_button }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                </a>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      {%- endif -%}

    </div>
  </div>
</section>
{% schema %}
{
  "name": "Collection list",
  "settings": [
    {
      "type": "header",
      "content": "Section width"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Section width",
      "options": [
        { "label": "Fluid", "value": "fluid" },
        { "label": "Normal", "value": "normal" }
      ],
      "default": "fluid"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "paragraph",
      "content": "Tablet"
    },
    {
      "type": "range",
      "id": "section_padding_top_ipad",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom_ipad",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "section_subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link URL"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all link text",
      "default": "Shop All"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "text",
      "id": "cat_button",
      "label": "Shop button text",
      "default": "Shop Now"
    },
    {
      "type": "checkbox",
      "id": "show_all_collections",
      "label": "Show all collections automatically",
      "info": "Displays all store collections instead of manually selected blocks.",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slider_cat",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "slider_category_handle",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "cat_img",
          "label": "Custom image",
          "info": "Recommended size: 480x720px (2:3 portrait)"
        },
        {
          "type": "text",
          "id": "cat_custom_title",
          "label": "Custom title (overrides collection name)"
        },
        {
          "type": "textarea",
          "id": "cat_description",
          "label": "Description (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "slider_cat" },
        { "type": "slider_cat" },
        { "type": "slider_cat" },
        { "type": "slider_cat" }
      ]
    }
  ]
}
{% endschema %}
