{{ 'custom-banner.css' | asset_url | stylesheet_tag }}
<section class="custom-banner" style="--padding-top: {{ section.settings.section_padding_top }}px; --padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-ipad: {{ section.settings.section_padding_top_ipad }}px; --padding-bottom-ipad: {{ section.settings.section_padding_bottom_ipad }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px; --padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px; --background-color: {{ section.settings.section_bg_color }};">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid{% else %}container{% endif %}">
    <div class="banner-split">

      <div class="banner-image-col">
        <a href="{{ section.settings.button_url }}" class="banner-img-wrap">
          {%- if section.settings.banner_img != blank -%}
            {{
              section.settings.banner_img
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                width: section.settings.banner_img.width,
                height: section.settings.banner_img.height,
                class: 'lazyload',
                alt: section.settings.banner_img.alt | escape
            }}
          {%- else -%}
            {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </a>
      </div>

      <div class="banner-text-col">
        <div class="banner-text-inner">
          {%- if section.settings.section_title != blank -%}
            <h2 class="banner-heading" data-fade-in>{{ section.settings.section_title }}</h2>
          {%- endif -%}
          {%- if section.settings.section_desc != blank -%}
            <p class="banner-desc" data-fade-in>{{ section.settings.section_desc }}</p>
          {%- endif -%}
          {%- if section.settings.section_desc2 != blank -%}
            <p class="banner-desc" data-fade-in>{{ section.settings.section_desc2 }}</p>
          {%- endif -%}
          {%- if section.settings.section_button != blank -%}
            <a href="{{ section.settings.button_url }}" class="banner-link" data-fade-in>
              {{ section.settings.section_button }}&nbsp;&rarr;
            </a>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>
{% schema %}
{
  "name": "Custom banner",
  "settings": [
    {
      "type": "header",
      "content": "Section width"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Section width",
      "options": [
        {
          "label": "Fluid",
          "value": "fluid"
        },
        {
          "label": "Normal",
          "value": "normal"
        }
      ],
      "default": "fluid"
    },
    {
      "type": "header",
      "content": "Section space top bottom"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "paragraph",
      "content": "Ipad"
    },
    {
      "type": "range",
      "id": "section_padding_top_ipad",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom_ipad",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section background color"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "section_bg_img",
      "label": "Image",
      "info": "Recommended size: 1350x350px"
    },
    {
      "type": "checkbox",
      "id": "section_bg_img_enable",
      "label": "Show background image",
      "default": false
    },
    {
      "type": "header",
      "content": "Banner image"
    },
    {
      "type": "image_picker",
      "id": "banner_img",
      "label": "Banner image",
      "info": "Recommended size: 800x1000px"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Banner title",
      "default": "Relaxed Fit, Modern Style."
    },
    {
      "type": "textarea",
      "id": "section_desc",
      "label": "Banner description",
      "default": "Crafted for the way you move — effortless silhouettes that carry you from morning to evening with ease."
    },
    {
      "type": "textarea",
      "id": "section_desc2",
      "label": "Banner description 2",
      "default": "Discover our latest collection, where comfort meets contemporary design."
    },
    {
      "type": "text",
      "id": "section_button",
      "label": "Banner link text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Banner url"
    }
  ],
  "presets": [
    {
      "name": "Custom banner"
    }
  ]
}
{% endschema %}
<style>
.custom-banner .banner-split {
  {% if section.settings.section_bg_img_enable %}
  background-image: url('{% if section.settings.section_bg_img %}{{ section.settings.section_bg_img | image_url }}{% else %}https://dummyimage.com/1350x350/f7f7f7/999999{% endif %}');
  background-repeat: no-repeat;
  background-position: center;
  background-size: cover;
  {% endif %}
}
</style>
