<style>
  .video-deal-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }
  @media (max-width: 1199px) {
    .video-deal-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_ip }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_ip }}px;
    }
  }
  @media (max-width: 767px) {
    .video-deal-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_xs }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
    }
  }
  .video-deal-{{ section.id }} .video-deal {
    display: flex;
    flex-wrap: wrap;
    margin-top: -30px;
    margin-inline-start: -30px;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner {
    width: calc(33.33% - 30px);
    margin-top: 30px;
    margin-inline-start: 30px;
  }
  @media (max-width: 1199px) {
    .video-deal-{{ section.id }} .video-deal .video-banner,
    .video-deal-{{ section.id }} .video-deal .video-banner {
      width: calc(50% - 30px);
    }
    .video-deal-{{ section.id }} .video-deal {
      justify-content: center;
    }
  }
  @media (max-width: 767px) {
    .video-deal-{{ section.id }} .video-deal {
      margin-top: -12px;
      margin-inline-start: -12px;
    }
    .video-deal-{{ section.id }} .video-deal .video-banner,
    .video-deal-{{ section.id }} .video-deal .video-banner {
      width: calc(50% - 12px);
      margin-top: 12px;
      margin-inline-start: 12px;
    }
  }
  @media (max-width: 600px) {
    .video-deal-{{ section.id }} .video-deal .video-banner,
    .video-deal-{{ section.id }} .video-deal .video-banner {
      width: calc(100% - 12px);
    }
  }

  /* video banner css */
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main {
    position: relative;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main span.video-image {
    position: relative;
    overflow: hidden;
    display: block;
    border-radius: var(--sti-border-radius);
  }
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main,
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main span.video-image,
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main span.video-image img {
    height: 100%;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main span.video-image img {
    object-fit: cover;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main .video-content {
    position: absolute;
    top: 80px;
    left: 60px;
    right: 60px;
    text-align: center;
  } 
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main .video-content a.video-btn span.icon {
    position: relative;
    background-color: #fff;
    width: 90px;
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 100%;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main .video-content a.video-btn span.icon::before {
    -webkit-animation: hovereffect 2s linear infinite;
    -moz-animation: hovereffect 2s linear infinite;
    animation: hovereffect 2s linear infinite;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main .video-content a.video-btn span.icon::after {
    -webkit-animation: hovereffect 4s linear infinite;
    -moz-animation: hovereffect 4s linear infinite;
    animation: hovereffect 4s linear infinite;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main .video-content a.video-btn span.icon::before,
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main .video-content a.video-btn span.icon::after {
    background-color: var(--font-color-primary);
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 100%;
  }
  @keyframes hovereffect {
    0%{
      opacity: 1;
    }
    40%{
      opacity: 1;
    }
    100%{
      opacity: 0;
      -webkit-transform: scale(1.3);
      -moz-transform: scale(1.3);
      -ms-transform: scale(1.3);
      transform: scale(1.3);
    }
  }
  .video-deal-{{ section.id }} .video-deal .video-banner .video-main .video-content a.video-btn span.icon i {
    color: var(--background-color-body);
    font-size: 18px;
