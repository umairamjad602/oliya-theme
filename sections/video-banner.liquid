    object-fit: cover;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner.banner-first .deal-main .deal-content {
    position: absolute;
    top: 60px;
    left: 30px;
    right: 30px;
    text-align: center;
  }
  .video-deal-{{ section.id }} .video-deal .video-banner.banner-last .deal-main .deal-content {
