}
.video-deal-{{ section.id }} .video-deal .video-banner .deal-main .deal-content .deal-title h2.title {
  font-size:  40px;
  font-family: var(--font-custom-stack-section-header);
  font-weight: var(--font-custom-weight-header);
  line-height: 1.2;
