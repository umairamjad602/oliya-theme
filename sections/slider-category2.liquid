
<link href="{{ 'slider-category2-css.css' | asset_url }}" rel="stylesheet" type="text/css" media="all">
<section class="slider-category2-area">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        {% if section.settings.section_title != '' or section.settings.section_sub_title != '' %}
        <div class="section-capture">
          <div class="section-title">
            {% if section.settings.section_sub_title != '' %}
            <span class="sub-title" data-fade-in>{{ section.settings.section_sub_title }}</span>
            {% endif %}
            {% if section.settings.section_title != '' %}
            <h2 data-fade-in>{{ section.settings.section_title }}</h2>
            {% endif %}
          </div>
        </div>
        {% endif %}
        <div class="category-main">
          <div class="category-tab">
            <ul class="nav nav-tabs" role="tablist">
              <li role="presentation" data-fade-in>
                <a class="active show" role="tab" data-bs-toggle="tab" href="#tab-1-{{ section.id }}">
                  <span class="tab-title">{{- section.settings.category_tab_1_title | default: 'Collection' -}}</span>
                  <span class="tab-arrow"><i class="{% if request.locale.iso_code == 'ar' %}feather-chevron-left{% else %}feather-chevron-right{% endif %}"></i></span>
                  {% assign category_product = collections[section.settings.category_tab_collection_1] %}
                    <span class="category-item">
                      <span class="count">{{ category_product.products.count | default: "0" }}+ </span>
                      <span class="rightarrow-cat"><i class="ri-arrow-right-up-line"></i></span>
                      {% if category_product.products.count == 0 or category_product.products.count == 1 %}
                      <span class="item">{{ section.settings.item_label }}</span>
                      {%- else -%}
                      {% endif %}           
                    </span>
                </a>
              </li>
              <li role="presentation" data-fade-in>
                <a class="" role="tab" data-bs-toggle="tab" href="#tab-2-{{ section.id }}">
                  <span class="tab-title">{{- section.settings.category_tab_2_title | default: 'Collection' -}}</span>
