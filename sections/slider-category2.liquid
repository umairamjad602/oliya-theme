              <div class="tab-pane fade active show" id="tab-1-{{ section.id }}" role="tabpanel">
                <div class="category-sub-slider swiper" id="category-tab-{{ section.id }}" data-slides-per-view="{{ section.settings.category_special_product_limit }}">
                  <div class="swiper-wrapper">
                    {% for block in section.blocks %}
                    {%- case block.type -%}
                    {%- when 'category_1_tab' -%}
                    {% assign category_product = collections[block.settings.category_tab_collection_1] %}
                    <div class="swiper-slide" data-fade-in>
                      <div class="category-sub-item" style="background-color: {{ section.settings.sub_item_bg }};">
                        <div class="category">
                          <a href="{{ category_product.url }}" class="collection-title">{{ category_product.title | default: 'Collection' }}</a>
                          <span class="image-sub">
                            {%- if block.settings.catimage1 -%}
                            {{ block.settings.catimage1 | image_url: width: 512 | image_tag:
                            loading: 'lazy',
                            width: block.settings.catimage1.width,
                            height: block.settings.catimage1.height,
                            class: "img-fluid lazyload",
                            alt: block.settings.catimage1.alt | escape }}
                            {%- else -%}
                            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                            {%- endif -%}
                          </span>
                          <div class="category-sub-content">
