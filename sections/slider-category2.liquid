              <script type="text/javascript">
                addEventListener('DOMContentLoaded', (event) => {
                  var swiper = new Swiper('#category-tab-{{ section.id }}', {
                    loop: false,
                    slidesPerView: {{ section.settings.category_sub_item }},
                    grid: {
                      rows: {{ section.settings.category_sub_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12,
                    observer: true,
                    observeParents: true,
                    watchSlidesProgress: true,
                    {% if request.locale.iso_code == 'ar' %}
                    rtl: true,
                    {%- endif -%}
                    navigation: {
                      nextEl: '.swiper-next-{{ section.id }}',
                      prevEl: '.swiper-prev-{{ section.id }}',
                    },
                    pagination: {
                      el: ".swiper-pagination-{{ section.id }}",
                      clickable: true
                    },
                    autoplay: {
                      delay: 5000,
                      disableOnInteraction: false,
                      pauseOnMouseEnter: true
                    },
                    speed: 1000,
                    breakpoints: {
                      0: {
                        slidesPerView: 1,
                        grid: {
                          rows: {{ section.settings.category_sub_col }},
                          fill: 'row' | 'column',
                        },
                        spaceBetween: 12,
                      },
                      320: {
                        slidesPerView: 2,
                        grid: {
                          rows: {{ section.settings.category_sub_col }},
                          fill: 'row' | 'column',
                        },
                        spaceBetween: 12,
                      },
                      540: {
                        slidesPerView: 2,
                        grid: {
                          rows: {{ section.settings.category_sub_col }},
                          fill: 'row' | 'column',
                        },
                        spaceBetween: 12,
