<section class="newsletter-area-{{ section.id }}">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        <div class="news-letter-area" {% if section.settings.newsletter_bg_img_enable %}style="background-image: url({% if section.settings.newsletter_bg_img %}{{ section.settings.newsletter_bg_img | image_url }}{% else %}https://dummyimage.com/1380x350{% endif %});"{% endif %}>
          <div class="newsletter-block">
            {% if section.settings.newsletter_title != '' %}
            <div class="newsletter-title">
              <div class="section-capture">
                <div class="section-title">
                  <h2 class="title" style="color: {{ section.settings.newsletter_title_color }};">{{ section.settings.newsletter_title }}</h2>
                  <div class="decs-main">
                    <p class="desc" style="color: {{ section.settings.newsletter_desc_color }};">{{ section.settings.newsletter_desc }}</p>
                    <p class="desc" style="color: {{ section.settings.newsletter_desc_color2 }};">{{ section.settings.newsletter_desc2 }}</p>
                  </div>
                </div>
              </div>
            </div>
            {% endif %}
            <div class="subscribe-content">
              {% form 'customer' %}
              {{ form.errors | default_errors }}
              {% if form.posted_successfully? %}
              <p class="text-success">
                <span class="subscribe-text">{{ settings.news-bg_success_text }} <span class="subscribe-code bg-success">{{ settings.news-bg_coupan_code }}</span></span>
              </p>
              {% endif %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="subscribe-block">
                <input type="email" name="contact[email]" class="email mail" id="E-mail" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="{{ 'general.newsletter_form.newsletter_email' | t }}" autocapitalize="off" required>
                <button class="news-btn" type="submit" name="commit" id="Subscribe">
                  {{ 'general.newsletter_form.submit' | t }}
                </button>
              </div>
              {% endform %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "header",
      "content": "Container"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "options": [
        {
          "label": "Fluid",
          "value": "fluid"
        },
        {
          "label": "Normal",
          "value": "normal"
        }
      ],
      "default": "normal"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "paragraph",
      "content": "Ipad"
    },
    {
      "type": "range",
      "id": "section_padding_top_lg",
      "label": "Section padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding_bottom_lg",
      "label": "Section padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Section padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Section padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section background color"
    },
    {
      "type": "checkbox",
      "id": "section_bg_color_enable",
      "label": "Show background color",
      "default": true
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#fff"
    },
    {
      "type": "header",
      "content": "Newsletter background image"
    },
    {
      "type": "checkbox",
      "id": "newsletter_bg_img_enable",
      "label": "Show background image",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "newsletter_bg_img",
      "label": "Image",
      "info": "Recommended size: 1380 x 262px"
    },
    {
      "type": "header",
      "content": "Newsletter background color"
    },
    {
      "type": "checkbox",
      "id": "newsletter_bg_color_enable",
      "label": "Show background color",
      "default": false
    },
    {
      "type": "color",
      "id": "newsletter_bg_color",
      "label": "Background color",
      "default": "#fff"
    },
    {
      "type": "header",
      "content": "Section title"
    },
    {
      "type": "textarea",
      "id": "newsletter_title",
      "label": "Title",
      "default": "Get <span>20%</span> off discount",
      "info": "Wrap your text between <span></span> to add the markers font."
    },
    {
      "type": "color",
      "id": "newsletter_title_color",
      "label": "Title color",
      "default": "#FFFFFF"
    },
    {
      "type": "textarea",
      "id": "newsletter_desc",
      "label": "Description",
      "default": "By subscribe our newsletter"
    },
    {
      "type": "color",
      "id": "newsletter_desc_color",
      "label": "Description color",
      "default": "#FFFFFF"
    },
    {
      "type": "textarea",
      "id": "newsletter_desc2",
      "label": "Description",
      "default": "By subscribe our newsletter"
    },
    {
      "type": "color",
      "id": "newsletter_desc_color2",
      "label": "Description color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "newsletter_button_style",
      "label": "Button style",
      "options": [
        {
          "label": "Button style1",
          "value": "btn-style1"
        },
        {
          "label": "Button style2",
          "value": "btn-style2"
        },
        {
          "label": "Button style3",
          "value": "btn-style3"
        }
      ],
      "default": "btn-style1"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
<style>
.newsletter-area-{{ section.id }} {
  position: relative;
  {% if section.settings.section_bg_color_enable %}
  background-color: {{ section.settings.section_bg_color }};
  {% endif %}
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
}
@media (max-width: 1199px) {
  .newsletter-area-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top_lg }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_lg }}px;
  }
}
@media (max-width: 767px) {
  .newsletter-area-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top_xs }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
  }
}
.newsletter-area-{{ section.id }} .news-letter-area {
  position: relative;
  padding: 55px 30px;
  {% if section.settings.newsletter_bg_img_enable %}
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  {% endif %}
  {% if section.settings.newsletter_bg_color_enable %}
  background-color: {{ section.settings.newsletter_bg_color }};
  {% endif %}
  border-radius: var(--sti-border-radius);
}

/* newsletter title css */
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block {
  width: 50%;
  margin: 0 auto;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture {
  margin-bottom: 0px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title {
  display: contents;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title h2 {
  line-height: 50px;
  border-right: 1px solid var(--font-color-body);
  padding-right: 40px;
  margin-right: 40px;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title h2 span {
  color: var(--font-color-primary);
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title .decs-main {
  text-align: left;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title p.desc {
  max-width: 100%;
  line-height: 1;
}
@media (max-width: 1199px) {
  .newsletter-area-{{ section.id }} .news-letter-area {
    padding: 45px 30px;
  }
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block {
    width: 66.67%;
  }
}
@media (max-width: 991px) {
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block {
    width: 100%;
  }
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title {
    text-align: center;
  }
}
@media (max-width: 767px) {
  .newsletter-area-{{ section.id }} .news-letter-area {
    padding: 40px 12px;
  }
}
@media (max-width: 600px) {
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title h2 {
    padding-right: 20px;
    margin-right: 20px;
  }
}
@media (max-width: 479px) {
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title {
    width: 100%;
  }
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title h2 {
    border-right: none;
    padding-right: 0px;
    margin: 0;
  }
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture {
    display: block;
    align-items: center;
    justify-content: center;
  }
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title .decs-main {
    text-align: center;
  }
}
@media (max-width: 320px) {
  .newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .newsletter-title .section-capture .section-title {
    width: 83.33%;
  }
}

/* newsletter css */
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .subscribe-content {
  margin-top: 20px;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .subscribe-content form .subscribe-block {
  position: relative;
  overflow: hidden;
  border-radius: var(--sti-border-radius);
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .subscribe-content form input,
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .subscribe-content form input .subscribe-block input {
  width: 100%;
  border: none;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .subscribe-content form input::placeholder {
  color: #808080;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .subscribe-content .subscribe-block button.news-btn {
  position: absolute;
  inset-inline-end: 0px;
  border-radius: 0px;
  color: var(--font-color-primary);
  background-color: var(--background-color-body);
  font-size: 16px;
  padding: 20px 30px;
  text-transform: uppercase;
  font-weight: 500;
  letter-spacing: 0px;
  text-align: center;
  line-height: 1;
  border-left: 1px solid #e2e2e2;
}
.newsletter-area-{{ section.id }} .news-letter-area .newsletter-block .subscribe-content .subscribe-block button:hover {
  color: var(--background-color-body);
  background-color: var(--font-color-primary);
}
</style>