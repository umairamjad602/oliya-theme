<style>
  .blog-section {
    background-color: var(--background-color);
  }
  .blog-section .blog-wrap {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }
  .blog-section .blog-wrap.left-sidebar .blog-article {
    grid-column: 2 / span 3;
  }
  .blog-section .blog-wrap.right-sidebar .blog-article {
    grid-column: 1 / span 3;
    order: -1;
  }
  .blog-section .blog-wrap.without-sidebar {
    grid-template-columns: repeat(1, 1fr);
  }
  @media (max-width: 1199px) {
    .blog-section .blog-wrap {
      grid-template-columns: repeat(3, 1fr);
    }
    .blog-section .blog-wrap.left-sidebar .blog-article {
      grid-column: 2 / span 2;
    }
    .blog-section .blog-wrap.right-sidebar .blog-article {
      grid-column: 1 / span 2;
    }
  }
  @media(max-width: 991px) {
    .blog-section .blog-wrap {
      grid-template-columns: repeat(1, 1fr);
    }
    .blog-section .blog-wrap.right-sidebar .blog-article,
    .blog-section .blog-wrap.left-sidebar .blog-article {
      grid-column: unset;
      order: -1;
    }
  }

  .blog-section ul.single-blog-area {
    display: grid;
    gap: 30px;
  }
  .blog-section ul.single-blog-area.grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .blog-section ul.single-blog-area.grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .blog-section ul.single-blog-area.grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }
  @media(max-width: 991px){
    .blog-section ul.single-blog-area.grid-4,
    .blog-section ul.single-blog-area.grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media(max-width: 600px){
    .blog-section ul.single-blog-area.grid-4,
    .blog-section ul.single-blog-area.grid-3,
    .blog-section ul.single-blog-area.grid-2 {
      grid-template-columns: repeat(1, 1fr);
    }
  }
</style>
