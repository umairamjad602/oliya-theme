<section
  class="blog-section"
  style="--padding-top: {{ section.settings.section_padding_top }}px; --padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-ipad: {{ section.settings.section_padding_top_ipad }}px; --padding-bottom-ipad: {{ section.settings.section_padding_bottom_ipad }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px; --padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px; --background-color: {{ section.settings.section_bgcolor }};"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="blog-wrap {{ section.settings.sidebar_handle }}">
      {%- unless section.settings.sidebar_handle == 'without-sidebar' -%}
      <div class="sidebar-wrapper blog-sidebar">
        {% render 'blog-sidebar' %}
      </div>
      {%- endunless -%}
      <div class="sidebar-wrapper blog-article">
        {%- assign blogs_limit = section.settings.blog_news_limit_handle -%}
        {%- paginate blog.articles by blogs_limit -%}
          <ul class="list-unstyled single-blog-area grid-{{ section.settings.blog_news_column }}">
            {% for article in blog.articles %}
              <li class="blog-slider">
                {% render 'blog-grid-item', article: article %}
              </li>
            {% endfor %}
          </ul>
          {% if paginate.pages > 1 %}
            <div class="paginatoin-area">
              {%- render 'pagination', paginate: paginate -%}
            </div>
          {% endif %}
        {%- endpaginate -%}
      </div>
    </div>
  </div>
</section>
