{{ 'article.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign ratio = 1
  if article.image and settings.blog_image_ratio == 'portrait'
    assign ratio = 0.8
  elsif article.image and settings.blog_image_ratio == 'adapt'
    assign ratio = article.image.aspect_ratio
  endif
  if ratio == 0 or ratio == null
    assign ratio = 1
  endif
-%}
<section
  class="article-section"
  style="--padding-top: {{ section.settings.section_padding_top }}px; --padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-ipad: {{ section.settings.section_padding_top_ipad }}px; --padding-bottom-ipad: {{ section.settings.section_padding_bottom_ipad }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px; --padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="blog-article-wrapper {{ section.settings.sidebar_handle }}">
      {%- unless section.settings.sidebar_handle == 'without-sidebar' -%}
        <div class="blog-article-wrap blog-sidebar">
          {% render 'blog-sidebar' %}
        </div>
      {%- endunless -%}
      <div class="blog-article-wrap blog-article">
        <div class="single-blog-area">
          <div class="single-blog-post">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                {%- when 'article_image' -%}
                  <div class="blog-post-opt" {{ block.shopify_attributes }}>
                    <div class="blog-image">
                      <a
                        href="{{ article.url }}"
                        class="banner-hover ratio"
                        style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
                      >
                        {%- if article.image != blank -%}
                          {% assign image_height = article.image.width | divided_by: article.image.aspect_ratio %}
                          {{
                            article.image
                            | image_url: width: 3000
                            | image_tag:
                              width: article.image.width,
                              height: image_height,
                              class: 'lazyload',
                              loading: 'lazy'
                          }}
                        {%- else -%}
                          {%- capture placeholder -%}hero-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
                          {{ placeholder | placeholder_svg_tag: 'placeholder-svg desk-img' }}
                        {%- endif -%}
                      </a>
                    </div>
                  </div>
                {%- when 'article_title' -%}
                  <div class="blog-post-opt opt" {{ block.shopify_attributes }}>
                    <div class="blog-revert">
                      <ul class="list-unstyled">
                        {%- if block.settings.article_date_enable -%}
                          <li class="date-time">
                            <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                          </li>
                        {%- endif -%}
                        {%- if block.settings.article_author_enable -%}
                          <li class="post-info">
                            <span>
                              {{- 'blogs.article.author_by' | t }}
                              {{ article.author | remove: '.' -}}
                            </span>
                          </li>
                        {%- endif -%}
                        {%- if block.settings.article_comment_enable -%}
                          <li class="blog-comment">
                            <span class="comment-count">
                              {%- if article.comments_count == 1 -%}
                                {{- 'blogs.comments.with_count.one' | t: count: article.comments_count -}}
                              {%- else -%}
                                {{- 'blogs.comments.with_count.other' | t: count: article.comments_count -}}
                              {%- endif -%}
                            </span>
                          </li>
                        {%- endif -%}
                      </ul>
                      <h1 class="post-title mr-0">{{ article.title }}</h1>
                    </div>
                  </div>
                {%- when 'article_content' -%}
                  <div class="blog-post-opt" {{ block.shopify_attributes }}>
                    <div class="blog-content">
                      {{ article.content }}
                    </div>
                  </div>
                {%- when 'article_tag' -%}
                  {% if article.tags.size > 0 %}
                    <div class="blog-post-opt opt" {{ block.shopify_attributes }}>
                      <div class="post-info-tag">
                        <ul class="list-unstyled post-tag">
                          {% for tag in article.tags %}
                            <li>{{ tag | link_to_tag: tag }}</li>
                          {% endfor %}
                        </ul>
                        <div class="blog-share">
                          {% render 'social-share-blog' %}
                        </div>
                      </div>
                    </div>
                  {% endif %}
                {%- when 'article_next_prev' -%}
                  <div class="blog-post-opt opt" {{ block.shopify_attributes }}>
                    <div class="blog-prev-next">
                      <ul class="list-unstyled">
                        <li>
                          <a href="{{ blog.previous_article }}">
                            <i class="feather-arrow-left"></i>
                            <span>{{ block.settings.blog_prev_button_title }}</span>
                          </a>
                        </li>
                        <li>
                          <a href="{{ blog.next_article }}">
                            <span>{{ block.settings.blog_next_button_title }}</span>
                            <i class="feather-arrow-right"></i>
                          </a>
                        </li>
                      </ul>
                    </div>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
          {% if article.comments_enabled? %}
            {% paginate article.comments by 5 %}
              <div id="comments" class="blog-comments">
                {% if article.comments.size > 0 %}
                  <div class="review_comment">
                    <div class="cmt-tit-count">
                      <h6 class="mr-0 comment-title">
                        <span class="cmt-title">{{ section.settings.article_cmt }}</span>
                        <span class="cmt-count">({{ article.comments_count }})</span>
                      </h6>
                    </div>
                    <div class="cmt-info-wrap">
                      {% for comment in article.comments %}
                        <div class="comment-info">
                          <div class="comment-avtar">
                            <div class="review-name">
                              <span class="avtar-cmt">
                                {% if section.settings.article_avtar_enable %}
                                  <i class="ri-user-add-line"></i>
                                {% else %}
                                  <span class="cmt-auth">{{ comment.author | slice: 0, 2 }}</span>
                                {% endif %}
                              </span>
                            </div>
                            <div class="review-info">
                              <span class="cmt-authr">{{ comment.author }}</span>
                              <span class="time">{{ comment.created_at | date: '%b %d, %Y' }}</span>
                            </div>
                          </div>
                          <div class="comment-content">
                            <div class="comment-desc">
                              {{ comment.content }}
                            </div>
                          </div>
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}
                {% if paginate.pages > 1 %}
                  <div class="paginatoin-area">
                    {%- render 'pagination', paginate: paginate -%}
                  </div>
                {% endif %}
              </div>
            {% endpaginate %}
            <div class="blog-comment-form">
              {% render 'blog-comment-form' %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
