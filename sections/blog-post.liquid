<style>
  .article-section {
    background-color: {{ section.settings.section_bgcolor }};
  }
  .article-section .blog-article-wrapper {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }
  .article-section .blog-article-wrapper.left-sidebar .blog-article {
    grid-column: 2 / span 3;
  }
  .article-section .blog-article-wrapper.right-sidebar .blog-article {
    grid-column: 1 / span 3;
    order: -1;
  }
  .article-section .blog-article-wrapper.without-sidebar {
    grid-template-columns: repeat(1, 1fr);
  }
  @media (max-width: 1199px) {
    .article-section .blog-article-wrapper {
      grid-template-columns: repeat(3, 1fr);
    }
    .article-section .blog-article-wrapper.left-sidebar .blog-article {
      grid-column: 2 / span 2;
    }
    .article-section .blog-article-wrapper.right-sidebar .blog-article {
      grid-column: 1 / span 2;
    }
  }
  @media(max-width: 991px) {
    .article-section .blog-article-wrapper {
      grid-template-columns: repeat(1, 1fr);
    }
    .article-section .blog-article-wrapper.right-sidebar .blog-article,
    .article-section .blog-article-wrapper.left-sidebar .blog-article {
      grid-column: unset;
      order: -1;
    }
  }
  

  .cmt-tit-count h6 {
    font-size: 18px;
    position: relative;
  }
  .cmt-info-wrap .comment-info {
    margin-top: 23px;
  }
  .cmt-info-wrap .comment-info:first-child {
    margin-top: 30px;
  }
  .cmt-info-wrap .comment-info .comment-avtar {
    display: flex;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-name .avtar-cmt,
  .cmt-info-wrap .comment-info .comment-avtar .review-name .avtar-cmt .cmt-auth {
    height: 45px;
    width: 45px;
    background-color: var(--font-color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-name .avtar-cmt {
    font-size: 20px;
    color: var(--font-color-header);
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-name .avtar-cmt .cmt-auth {
    font-size: var(--font-size-body);
    font-weight: 600;
    text-transform: uppercase;
    color: #fff;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-info {
    margin-inline-start: 15px;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-info span {
    display: block;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-info span.cmt-authr {
    color: var(--font-color-header);
    font-size: var(--font-size-body);
    font-weight: 600;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-info span.time {
    margin-top: 6px;
  }
  .cmt-info-wrap .comment-info .comment-content {
    margin-top: 7px;
  }
</style>
