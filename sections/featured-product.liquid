{%- assign product = section.settings.product_select -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}
<section
  class="product-details-page"
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;"
>
  {{ 'product-template.css' | asset_url | stylesheet_tag }}
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="pro_details_pos template-1 {% if section.settings.product_pos == 'left' %}pro_details_left_pos{% elsif section.settings.product_pos == 'right' %}pro_details_right_pos{% endif %}">
      <div class="product_detail_slider {% if section.settings.product_img_pos == 'top' or section.settings.product_img_pos == 'bottom' %}product_details_tb{% elsif section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}product_details_lr{% endif %} product_details{% if section.settings.product_pos_sticky_enable %} product_details_sticky{% endif %}">
        <div class="product_detail_img{% if section.settings.product_img_pos == 'top' %} product_detail_img_top{% elsif section.settings.product_img_pos == 'bottom' %} product_detail_img_bottom{% elsif section.settings.product_img_pos == 'left' %} product_detail_img_left{% elsif section.settings.product_img_pos == 'right' %} product_detail_img_right{% endif %}">
          {% if product != blank %}
          <div class="pro-slider">
            <div
              class="slider-small swiper slider-small-{{ section.id }}-{{ product.id }}"
              id="slider-small-{{ section.id }}-{{ product.id }}"
              data-slides-per-view="5"
            >
              <div class="swiper-wrapper">
                {% for media in product.media %}
                  {% assign i = forloop.index %}
                  {%- liquid
                    assign img_url = media | image_url
                    assign ratio = 1
                    if media.preview_image and section.settings.image_ratio == 'portrait'
                      assign ratio = 0.8
                    elsif media.preview_image and section.settings.image_ratio == 'adapt'
                      assign ratio = img_url.aspect_ratio
                    endif
                    if ratio == 0 or ratio == null
                      assign ratio = 1
                    endif
                  -%}
                  <div
                    class="swiper-slide"
                    data-layout="thumb-slider"
                    data-image="{{ media.src | image_url }}"
                    data-image-id="{{ media.id }}"
                    data-index="{{ i }}"
                    {% if section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}
                      data-slide="vertical"
                    {% else %}
                      data-slide="horizontal"
                    {% endif %}
                  >
                    <span class="product-thumb" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
                      {% assign image_height = media.preview_image.width
                        | divided_by: media.preview_image.aspect_ratio
                      %}
                      {{
                        media.preview_image
                        | image_url: width: 300
                        | image_tag:
                          width: media.preview_image.width,
                          height: image_height,
                          class: 'lazyload',
                          loading: 'lazy'
                      }}
                      {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                        <span class="icon-play"><i class="feather-play"></i></span>
                      {%- endif -%}
                      {%- if media.media_type == 'model' -%}
                        <span class="icon-modal"><i class="feather-box"></i></span>
                      {%- endif -%}
                    </span>
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
          <div class="product_img_top">
            <div
              class="slider-big swiper slider-big-{{ section.id }}-{{ product.id }}"
              id="slider-big-{{ section.id }}-{{ product.id }}"
              data-slides-per-view="1"
            >
              <div class="swiper-wrapper">
                {%- for media in product.media -%}
                  {% assign i = forloop.index %}
                  <div
                    class="swiper-slide"
                    data-layout="thumb-slider"
                    data-image="{{ media.src | image_url }}"
                    data-image-id="{{ media.id }}"
                    data-index="{{ i }}"
                  >
                    {% render 'media', media: media, section: section %}
                  </div>
                {%- endfor -%}
              </div>
              <div class="big-button button-next"><i class="feather-arrow-right"></i></div>
              <div class="big-button button-prev"><i class="feather-arrow-left"></i></div>
            </div>
          </div>
          {% else %}
          {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg desk-img' }}
          {% endif %}
        </div>
      </div>
      <div class="product_details_wrap {% if section.settings.product_img_pos == 'top' or section.settings.product_img_pos == 'bottom' %}product_details_tb{% elsif section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}product_details_lr{% endif %} product_details">
        <div class="product_details_info">
          <div class="pro-nprist">
            <div
              id="ProductInfo-{{ section.id }}"
              data-section="{{ section.id }}"
              data-url="{{ product.url }}"
              class="product__info-container"
            >
              {%- assign product_form_id = 'product-form-' | append: section.id -%}
              {%- liquid
                for block in section.blocks
                  case block.type
                    when '@app'
                      render 'product-template-app', product: product, block: block, section: section
                    when 'custom_html'
                      render 'product-template-custom-html', product: product, block: block, section: section
                    when 'custom_text'
                      render 'product-template-custom-text', product: product, block: block
                    when 'custom_liquid'
                      render 'product-template-custom-liquid', product: product, block: block, section: section
                    when 'product_title'
                      render 'product-template-title', product: product, block: block, section: section
                    when 'product_price'
                      render 'product-template-price', product: product, block: block, section: section, current_variant: current_variant, use_variant: true
                    when 'short_description'
                      render 'product-template-short-description', product: product, block: block, section: section
                    when 'description'
                      render 'product-template-description', product: product, block: block, section: section
                    when 'product_stock_inventory'
                      render 'product-template-stock', product: product, block: block, section: section, current_variant: current_variant
                    when 'product_variant_picker'
                      render 'product-template-variant', product: product, block: block, section: section, product_form_id: product_form_id
                    when 'product_quantity'
                      render 'product-template-quantity', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true
                    when 'product_buy_buttons'
                      render 'product-template-button', block: block, product: product, product_form_id: product_form_id, section: section, section_id: section.id, show_pickup_availability: true
                    when 'product_sku'
                      render 'product-template-sku', product: product, block: block, section: section, current_variant: current_variant
                    when 'product_payment'
                      render 'product-template-payment', product: product, block: block, section: section
                    when 'product_modal'
                      render 'product-template-modal', product: product, block: block, section: section
                    when 'complementary'
                      render 'product-template-complementary', product: product, block: block, section: section
                    when 'collapsible'
                      render 'product-template-collapse', product: product, block: block, section: section
                    when 'popup'
                      render 'product-template-popup', product: product, block: block, section: section
                    when 'icon_with_text'
                      render 'product-template-service', product: product, block: block, section: section
                    when 'line_item_property'
                      render 'product-template-line-item', product: product, block: block, section: section, product_form_id: product_form_id
                  endcase
                endfor
              -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script type="text/javascript">
    (function() {
      setTimeout(function () {
        {% if section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}
        function setheight(){
          var element = document.getElementById('slider-big-{{ section.id }}-{{ product.id }}');
          var height = element.offsetHeight;
          document.getElementById('slider-small-{{ product.id }}').style.maxHeight = height+"px";
        };
        $(document).bind('DOMSubtreeModified', function () {
          setheight();
        });
        {% endif %}
        var swiper = new Swiper(".slider-small-{{ section.id }}-{{ product.id }}", {
        spaceBetween: 15,
        {% if section.settings.product_img_pos == 'top' or section.settings.product_img_pos == 'bottom' %}
        slidesPerView: 5,
        {% endif %}
        {% if section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}
        direction: 'vertical',
        slidesPerView: "auto",
        mousewheel: true,
        slideToClickedSlide: true,
        loopedSlides: 50,
        {% endif %}
          breakpoints: {
            0: {
              slidesPerView: 3,
              direction: 'horizontal'
            },
            320: {
              slidesPerView: 3,
              direction: 'horizontal'
            },
            480: {
              {% if section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}
              direction: 'vertical',
              slidesPerView: "auto",
              {% endif %}
              {% if section.settings.product_img_pos == 'top' or section.settings.product_img_pos == 'bottom' %}
              slidesPerView: 5,
              {% endif %}
            },
          }
        });
        var swiper2 = new Swiper(".slider-big-{{ section.id }}-{{ product.id }}", {
          spaceBetween: 0,
          slidesPerView: 1,
          autoHeight: true,
          slideToClickedSlide: true,
          loopedSlides: 50,
          navigation: {
            nextEl: ".button-next",
            prevEl: ".button-prev"
          },
          thumbs: {
            swiper: swiper
          }
        });
        $(".option-block .op-lb").click(function(){
          var op_select = $(this).text();
          $(this).parents('.variant-option-block').find('.current-option').html(op_select);
        });
        if( $(".product-count-sale").length > 0 ){
          var id_product = $(".product-count-sale").data("id_product");
          var min = $(".product-count-sale").data("min") ? $(".product-count-sale").data("min") : 30;
          var max = $(".product-count-sale").data("max") ? $(".product-count-sale").data("max") : 40;
          var time_min = $(".product-count-sale").data("time_min") ? $(".product-count-sale").data("time_min") : 30;
          var time_max = $(".product-count-sale").data("time_max") ? $(".product-count-sale").data("time_max") : 40;
        var rand = Math.round(Math.random() * (max - min)) + min;
        var time = Math.round(Math.random() * (time_max - time_min)) + time_min;
        $("span.count",".product-count-sale").html(rand);
        $("span.time",".product-count-sale").html(time);
        }
        document.querySelectorAll('.week-countdown').forEach(function (el) {
  var endDate = el.getAttribute('data-enddate');
  var parsedDate = new Date(endDate);

  if (!isNaN(parsedDate)) {
    $(el).find('span').countdown(parsedDate, {
      defer: true
    }).on('update.countdown', function (event) {
      $(this).html(event.strftime('%D : %H : %M : %S'));
    }).on('finish.countdown', function () {
      // Hide the full countdown block when countdown ends
      el.style.display = 'none';
    }).countdown('start');
  }
});

      },1000);
    })();
    document.addEventListener('DOMContentLoaded', function () {
      function isIE() {
        const ua = window.navigator.userAgent;
        const msie = ua.indexOf('MSIE ');
        const trident = ua.indexOf('Trident/');
        return msie > 0 || trident > 0;
      }
      if (!isIE()) return;
      const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
      const noScriptInputWrapper = document.createElement('div');
      const variantSwitcher =
        document.querySelector('pr-option[data-section="{{ section.id }}"]') ||
        document.querySelector('selects-box[data-section="{{ section.id }}"]');
      noScriptInputWrapper.innerHTML = document.querySelector(
        '.pro-form-noscript-{{ section.id }}'
      ).textContent;
      variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

      document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function (event) {
        hiddenInput.value = event.currentTarget.value;
      });
    });
    {% if section.settings.zoom_enable %}
    function zoom(e){
      var zoomer = e.currentTarget;
      e.offsetX ? offsetX = e.offsetX : offsetX = e.touches[0].pageX
      e.offsetY ? offsetY = e.offsetY : offsetX = e.touches[0].pageX
      x = offsetX/zoomer.offsetWidth*100
      y = offsetY/zoomer.offsetHeight*100
      zoomer.style.backgroundPosition = x + '% ' + y + '%';
    }
    {% endif %}
  </script>
</section>
{% render 'product-template-ask-modal', product: product %}
