<style>
  .testimonial-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    background: {{ section.settings.section_bg_color }};
    overflow: hidden;
  }
  @media (max-width: 1199px) {
    .testimonial-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_ipad }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_ipad }}px;
    }
  }
  @media (max-width: 767px) {
    .testimonial-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_xs }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
    }
  }

  /* section heading css */
  .testimonial-{{ section.id }} .testimonial-heading {
    position: relative;
    text-align: center;
  }
  .testimonial-{{ section.id }} .testimonial-heading h2.heading {
    font-size: 150px;
    position: absolute;
    top: -180px;
    left: 0px;
    right: 0px;
    font-weight: var(--font-custom-weight-section-header);
    line-height: 1;
  }
  @media (max-width: 1199px) {
    .testimonial-{{ section.id }} .testimonial-heading h2.heading {
      top: -120px;
    }
    .testimonial-{{ section.id }} .testimonial-heading h2.heading {
      font-size: 80px;
    }
  }
  @media (max-width: 767px) {
    .testimonial-{{ section.id }} .testimonial-heading h2.heading {
      top: -100px;
    }
  }
  @media (max-width: 600px) {
    .testimonial-{{ section.id }} .testimonial-heading h2.heading {
      top: -80px;
    }
    .testimonial-{{ section.id }} .testimonial-heading h2.heading {
      font-size: 40px;
    }
  }

  /* testimonial css */
  .testimonial-{{ section.id }} .testimonial-main {
    background-color: #FFFFFF;
    padding: 30px;
    display: flex;
    align-items: center;
    border-radius: var(--sti-border-radius);
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-author {
    display: flex;
    align-items: center;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-author .author-image span.image {
    width: 80px;
    border-radius: 100%;
    overflow: hidden;
    display: block;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-author .author-image span.image svg {
    width: 100%;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-author .author-text {
    padding-inline-start: 15px;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-author .author-text h4.author-title {
    color: var(--font-color-header);
    font-size: var(--subtitle-font-size-body);
    font-weight: var(--subtitle-custom-font-weight-body);
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-author .author-text p.author-bio {
    margin-top: 3px;
    margin-bottom: 0px;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-desc {
    margin-top: 24px;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-desc p.desc {
    color: var(--font-color-header);
    font-size: var(--subtitle-font-size-body);
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-review {
    margin-top: 26px;
    display: flex;
    align-items: center;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-review span.review-icon {
    display: flex;
    line-height: 0;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-review span.review-icon i {
    color: #EFA505;
    font-size: 16px;
    {% if request.locale.iso_code == 'ar' %}
    margin-left: 5px;
    {%- else -%}
    margin-right: 5px;
    {%- endif -%}
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-review span.review-icon  i:last-child {
    {% if request.locale.iso_code == 'ar' %}
    margin-left: 0px;
    {%- else -%}
    margin-right: 0px;
    {%- endif -%}
  }
  .testimonial-area .testimonial-main .testi-desc .review-count span.review-icon i::before {
    content: "\f006";
  }
  .testimonial-area .testimonial-main .testi-desc .review-count span.review-icon i.fill::before {
    content: "\f005";
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-review p.count {
    line-height: 1;
    color: var(--font-color-primary);
    margin: 0px;
    margin-left: 10px;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-review span.review-label {
    line-height: 1;
    border-bottom: 1px solid;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-left {
    border-radius: var(--sti-border-radius);
    overflow: hidden;
  }
  .testimonial-{{ section.id }} .testimonial-main .testi-right {
    margin-left: 60px;
  }
  @media (max-width: 1499px) {
    .testimonial-{{ section.id }} .testimonial-main {
      padding: 40px;
    }
  }
   @media (max-width: 767px) {
    .testimonial-{{ section.id }} .testimonial-main {
      padding: 15px 25px;
    }
  }
  @media (max-width: 1199px) {
    .testimonial-{{ section.id }} .testimonial-main {
      padding: 30px;
      display: block;
      align-items: center;
    }
    .testimonial-{{ section.id }} .testimonial-main .testi-right {
      margin-left: 0px;
      margin-top: 30px;
    }
  }

  /* slider arrow css */
  .testimonial .slider-arrow {
    display: flex;
    align-items: center;
  }
  .testimonial .slider-arrow span {
    color: var(--font-color-body);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 45px;
    height: 45px;
    font-size: 18px;
    border-radius: var(--sti-border-radius);
    line-height: 1;
    margin-inline-end: 10px;
    border: var(--sti-border);
    background-color: transparent;
    -webkit-transition: all .3s ease-in-out 0s;
    -o-transition: all .3s ease-in-out 0s;
    transition: all .3s ease-in-out 0s;
  }
  {% if request.locale.iso_code == 'ar' %}
  .testimonial .slider-arrow span i {
    transform: scaleX(-1);
  }
  {% endif %}
  .testimonial .slider-arrow span:last-child {
    margin-inline-end: 0;
  }
  .testimonial .slider-arrow span:hover {
    color: #FFFFFF;
    background-color: var(--font-color-primary);
  }
  @media(max-width: 1199px){
    .testimonial .slider-arrow {
      margin-top: 20px;
    }
    .testimonial .slider-arrow span{
      width: 35px;
      height: 35px;
    }
  }
</style>