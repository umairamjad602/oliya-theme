<section class="testimonial-{{ section.id }}">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        {% if section.settings.section_subheading != '' or section.settings.section_heading != '' or section.settings.section_description != '' %}
          <div class="section-capture">
            <div class="section-title">
              {% if section.settings.section_subheading != '' %}
              <span data-fade-in class="sub-title">{{ section.settings.section_subheading }}</span>
              {% endif %}
              {% if section.settings.section_heading != '' %}
              <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
              {% endif %}
              {% if section.settings.section_description != '' %}
              <p class="desc">{{ section.settings.section_description }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
        <div class="swiper" id="testimonial-slider-{{ section.id }}">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
            <div class="swiper-slide">
              <div class="testimonial-main">
              <div class="testi-left">
                {%- if block.settings.testimonial_author_left -%}
                  {{ block.settings.testimonial_author_left | image_url: width: 300 | image_tag:
                  loading: 'lazy',
                  width: block.settings.testimonial_author_left.width,
                  height: block.settings.testimonial_author_left.height,
                  class: "img-fluid lazyload",
                  alt: block.settings.testimonial_author_left.alt | escape }}
                  {%- else -%}
                  {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-300 h-300' }}
                  {%- endif -%}
              </div>
                <div class="testi-right">
                  <div class="testi-author">
                    <div class="author-image">
                      <span class="image">
                        {%- if block.settings.testimonial_author_image -%}
                        {{ block.settings.testimonial_author_image | image_url: width: 100 | image_tag:
                        loading: 'lazy',
                        width: block.settings.testimonial_author_image.width,
                        height: block.settings.testimonial_author_image.height,
                        class: "img-fluid lazyload",
                        alt: block.settings.testimonial_author_image.alt | escape }}
                        {%- else -%}
                        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                        {%- endif -%}
                      </span>
                    </div>
                    <div class="author-text">
                      {% if block.settings.testimonial_author_title != '' %}
                      <h4 class="author-title m-0">{{ block.settings.testimonial_author_title }}</h4>
                      {% endif %}
                      {% if block.settings.testimonial_author_bio != '' %}
                      <p class="author-bio">{{ block.settings.testimonial_author_bio }}</p>
                      {% endif %}
                    </div>
                  </div>
                  {% if block.settings.testimonial_author_desc != '' %}
                  <div class="testi-desc">
                    <p class="desc m-0">{{ block.settings.testimonial_author_desc }}</p>
                  </div>
                  {% endif %}
                  <div class="testi-review">
                    <span class="review-icon">
                      <i class="ri-star-fill{% if block.settings.pro_testi_review == '1' or block.settings.pro_testi_review == '2' or block.settings.pro_testi_review == '3' or block.settings.pro_testi_review == '4' or block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                      <i class="ri-star-fill{% if block.settings.pro_testi_review == '2' or block.settings.pro_testi_review == '3' or block.settings.pro_testi_review == '4' or block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                      <i class="ri-star-fill{% if block.settings.pro_testi_review == '3' or block.settings.pro_testi_review == '4' or block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                      <i class="ri-star-fill{% if block.settings.pro_testi_review == '4' or block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                      <i class="ri-star-fill{% if block.settings.pro_testi_review == '5' %} fill {% endif %}"></i>
                    </span>
                    <p class="count">( {% if block.settings.pro_testi_review == '1' %} 1.5 {% elsif block.settings.pro_testi_review == '2' %} 2.5 {% elsif block.settings.pro_testi_review == '3' %} 3.5 {% elsif block.settings.pro_testi_review == '4' %} 4.5 {% elsif block.settings.pro_testi_review == '5' %} 5.0 {% endif %}{{ section.settings.testi_review_label }} )</p>
                  </div>
                </div>


              </div>
            </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#testimonial-slider-{{ section.id }}', {
      loop: false,
      slidesPerView: 2,
      grid: {
        rows: 1,
        fill: 'row' | 'column',
      },
      spaceBetween: 30,
      observer: true,
      observeParents: true,
      watchSlidesProgress: true,
      {% if request.locale.iso_code == 'ar' %}
      rtl: true,
      {%- endif -%}
      navigation: {
        nextEl: ".arrow-next",
        prevEl: ".arrow-prev",
      },
      pagination: {
        el: ".swiper-pagination-{{ section.id }}",
        clickable: true
      },
      autoplay: {
        delay: 5000000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: 1000,
      breakpoints: {
        0: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        320: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        360: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        480: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        540: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        640: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        768: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1024: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1199: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1499: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        }
      }
    });
  });
</script>
