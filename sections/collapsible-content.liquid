{{ 'collapsible-content.css' | asset_url | stylesheet_tag }}
<section
  class="faq-page"
  style="--padding-top: {{ section.settings.section_padding_top }}px; --padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-ipad: {{ section.settings.section_padding_top_ipad }}px; --padding-bottom-ipad: {{ section.settings.section_padding_bottom_ipad }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px; --padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;
--background-color: {{ section.settings.section_background_color }};"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="content-qa-banner {% if section.settings.sidebar_enable %} sidebar-enable {% endif %}">
      {% if section.settings.sidebar_enable %}
        <div class="faq-sidebar">
          <div class="main-title">
            {% if section.settings.section_subheading != '' %}
              <span data-fade-in class="sub-title">{{ section.settings.section_subheading }}</span>
            {% endif %}
            {% if section.settings.section_heading != '' %}
              <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
            {% endif %}
          </div>
          <div class="faq-link">
            <ul class="list-unstyled link-page" role="tablist">
              {% if section.settings.page_title != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url }}" class="link-other">
                    {{- section.settings.page_title -}}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.page_title1 != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url1 }}" class="link-other">
                    {{- section.settings.page_title1 -}}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.page_title2 != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url2 }}" class="link-other">
                    {{- section.settings.page_title2 -}}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.page_title3 != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url3 }}" class="link-other">
                    {{- section.settings.page_title3 -}}
                  </a>
                </li>
              {% endif %}
              {% if section.settings.page_title4 != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url4 }}" class="link-other">
                    {{- section.settings.page_title4 -}}
                  </a>
                </li>
              {% endif %}
            </ul>
          </div>
        </div>
      {% endif %}
      <div class="que-ans" id="collapse-tab">
        <div class="accordian-block">
          <div class="main-title">
            {% if section.settings.accordian_title1 != '' %}
              <h2 class="mr-0" data-fade-in>{{ section.settings.accordian_title1 }}</h2>
            {% endif %}
          </div>
          <ul class="list-unstyled">
            {% liquid
              assign i = 0
            %}
            {% for block in section.blocks %}
              {%- case block.type -%}
                {%- when 'accordian1' -%}
                  {% assign i = i | plus: 1 %}
                  {% if block.settings.accordion_title != '' %}
                    <li data-fade-in {{ block.shopify_attributes }}>
                      <button
                      type="button"
                        data-bs-toggle="collapse"
                        aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
                        data-bs-target="#collapse-{{ section.id }}-{{ block.id }}-{{ i }}"
                        class="question accordian-btn"
                        aria-label="{{ block.settings.accordion_title }}"
                      >
                        <h6 class="que mr-0">{{ block.settings.accordion_title }}</h6>
                        <span class="que-accordian"><i class="feather-plus"></i></span>
                      </button>
                      <div
                        class="ans-accordian accordian-content collapse {% if forloop.first %} show{% endif %}"
                        id="collapse-{{ section.id }}-{{ block.id }}-{{ i }}"
                        data-bs-parent="#collapse-tab"
                      >
                        {% if block.settings.accordion_ans1 != '' %}
                          <p class="mr-0">{{ block.settings.accordion_ans1 }}</p>
                        {% endif %}
                        {% if block.settings.accordion_ans2 != '' %}
                          <p class="mr-0">{{ block.settings.accordion_ans2 }}</p>
                        {% endif %}
                      </div>
                    </li>
                  {% endif %}
              {% endcase %}
            {% endfor %}
          </ul>
        </div>
        <div class="accordian-block">
          <div class="main-title">
            {% if section.settings.accordian_title2 != '' %}
              <h2 class="mr-0" data-fade-in>{{ section.settings.accordian_title2 }}</h2>
            {% endif %}
          </div>
          <ul class="list-unstyled">
            {% liquid
              assign i = 0
            %}
            {% for block in section.blocks %}
              {%- case block.type -%}
                {%- when 'accordian2' -%}
