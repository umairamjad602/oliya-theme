    },
    {
      "type": "text",
      "id": "accordian_title1",
      "label": "Accordian heading",
      "default": "Shopping Information"
    },
    {
      "type": "text",
      "id": "accordian_title2",
      "label": "Accordian heading",
      "default": "Returns and exchanges"
    },
    {
      "type": "text",
