            %}
            {% for block in section.blocks %}
              {%- case block.type -%}
                {%- when 'accordian4' -%}
                  {% assign i = i | plus: 1 %}
                  {% if block.settings.accordion_title != '' %}
                    <li {{ block.shopify_attributes }}>
                      <button
