<style>
  .contact-section2 {
    padding-top: {{ section.settings.contact_us_3_padding_top }}px;
    padding-bottom: {{ section.settings.contact_us_3_padding_bottom }}px;
    background-color: {{ section.settings.section_bg_color }};
  }
  @media (max-width: 1199px) {
    .contact-section2 {
      padding-top: {{ section.settings.contact_us_3_padding_top_ip }}px;
      padding-bottom: {{ section.settings.contact_us_3_padding_bottom_ip }}px;
    }
  }
  @media (max-width: 767px) {
    .contact-section2 {
      padding-top: {{ section.settings.contact_us_3_padding_top_xs }}px;
      padding-bottom: {{ section.settings.contact_us_3_padding_bottom_xs }}px;
    }
  }

/* get touch css */

.contact-section2 .location-block {
  background-color: #fff;
  padding: 100px;
  margin-top: -16.66%;
}
.contact-section2 .location-block .add-block {
  text-align: center;
}
.contact-section2 .location-block .add-block .flag-img {
  max-width: 70px;
  margin: 0 auto;
}
.contact-section2 .location-block .add-block p {
  font-size: 18px;
  max-width: 75%;
  margin: 30px auto 0;
}
.contact-section2 .location-block .add-block .url-content {
  margin-top: 30px;
}
.contact-section2 .location-block .add-block .url-content .mobile {
  color: var(--font-color-body);
  font-size: 16px;
  display: block;
}

.contact-section2 .location-block .add-block .url-content .mail {
  color: var(--font-color-body);
  font-size: 18px;
  display: block;
  padding-top: 5px;
}
.contact-section2 .location-block .add-block .url-content a:hover {
  color: var(--font-color-header);
}
.contact-section2 .location-block .add-block .cnt-title {
  font-size: 22px;
  color: var(--font-color-primary);
  line-height: 1;
  margin-top: 30px;
  padding-bottom: 5px;
  border-bottom: 3px solid transparent;
  -webkit-transition: all .3s ease-in-out 0s;
  -o-transition: all .3s ease-in-out 0s;
  transition: all .3s ease-in-out 0s;
}
.contact-section2 .location-block .add-block:hover .cnt-title {
  border-color: var(--font-color-primary);
}
