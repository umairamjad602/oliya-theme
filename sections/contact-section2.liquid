<section class="contact-section2">
  <div class="banner-bg" id="banner-bg">
    {% if section.settings.banner_img != blank %}
      {{ section.settings.banner_img | image_url: width: 1920 | image_tag:
        loading: 'lazy',
        width: section.settings.banner_img.width,
        height: section.settings.banner_img.height,
        class: "img-fluid lazyload",
        alt: section.settings.banner_img.alt | escape
      }}
    {% else %}
      {% capture placeholder %}product-apparel-{% cycle 1, 2, 3, 4 %}{% endcapture %}
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    {% endif %}
  </div>

  <div class="{% if section.settings.container == 'fluid' %}container-fluid{% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        <div class="location-block" id="location-block">
          <div class="section-capture">
            <div class="section-title">
              {% if section.settings.section_sub_title != blank %}
                <span class="sub-title" data-fade-in>{{ section.settings.section_sub_title }}</span>
              {% endif %}
              {% if section.settings.section_title != blank %}
                <h2 data-fade-in>{{ section.settings.section_title }}</h2>
              {% endif %}
            </div>
          </div>

          <div class="location-slider owl-carousel" id="location-slider-{{ section.id }}">
            {% for block in section.blocks %}
              <div class="add-block">
                <span class="flag-img">
                  {% if block.settings.flag_img != blank %}
                    {{ block.settings.flag_img | image_url: width: 200 | image_tag:
                      loading: 'lazy',
                      width: block.settings.flag_img.width,
                      height: block.settings.flag_img.height,
                      class: "img-fluid lazyload",
                      alt: block.settings.flag_img.alt | escape
                    }}
                  {% else %}
                    {% capture placeholder %}product-apparel-{% cycle 1, 2, 3, 4 %}{% endcapture %}
                    {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                  {% endif %}
                </span>

                <p>{{ block.settings.address_text }}</p>

                <div class="url-content">
                  {% if block.settings.add_mobile != blank %}
                    <a class="mobile" href="tel:{{ block.settings.add_mobile }}">{{ block.settings.add_mobile }}</a>
                  {% endif %}
                  {% if block.settings.add_email != blank %}
                    <a class="mail" href="mailto:{{ block.settings.add_email }}">{{ block.settings.add_email }}</a>
                  {% endif %}
                </div>

                <span class="cnt-title">{{ block.settings.country_name }}</span>
              </div>
            {% endfor %}
          </div>
          
        </div>
      </div>
    </div>
  </div>
</section>

<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    $('#location-slider-{{ section.id }}').owlCarousel({
      loop: false,
      rewind: true,
      items: 4,
      center: false,
      margin: 30,
      nav: true,
      navText: ['<i class=" feather-arrow-left"></i>','<i class="feather-arrow-right"></i>'],
      dots: false,
      {%- if settings.enable_rtl -%}
      rtl: true,
      {%- endif -%}
      responsive: {
        0: {
          items: 1,
          margin: 12
        },
        479: {
          items: 1,
          margin: 12
        },
        540: {
          items: 1,
          margin: 12
        },
        640: {
          items: 1,
          margin: 12
        },
        768: {
          items: 2
        },
        979: {
          items: 3
        },
        1199: {
          items: 4
        }
      }
    });
  });
</script>
{% schema %}
