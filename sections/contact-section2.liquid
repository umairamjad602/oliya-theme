.contact-section2 .location-slider {
  display: flex;
  align-items: center;
}
.contact-section2 .location-slider .owl-nav button {
  font-size: 24px;
  line-height: 1;
  position: absolute;
}
.contact-section2 .location-slider .owl-nav button.owl-prev {
