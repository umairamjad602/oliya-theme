{% assign featured_tab_enable = section.settings.featured_tab_enable %}
<section
  class="featured-collection fe-coll-{{ section.id }}"
  style="--background-color: {{ section.settings.section_bg_color }};"
>
  <div class="container-fluid">
    {% if section.settings.section_subheading != '' or section.settings.section_heading != '' %}
    <div class="section-capture {% if section.settings.countdown_enable %} deal-counter {% endif %}">
      <div class="section-title">
        {% if section.settings.section_subheading != '' %}
          <span data-fade-in class="sub-title">{{ section.settings.section_subheading }}</span>
        {% endif %}
        {% if section.settings.section_heading != '' %}
          <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
        {% endif %}
      </div>
      {% if section.settings.countdown_enable %}
        <ul data-fade-in class="contdown_row list-unstyled">
          <li class="countdown_section">
            <span id="days-{{ section.id }}" class="countdown_timer"></span>
            <span class="countdown_title">{{ settings.day_title }}</span>
          </li>
          <li class="countdown_section">
            <span id="hours-{{ section.id }}" class="countdown_timer"></span>
            <span class="countdown_title">{{ settings.hour_title }}</span>
          </li>
          <li class="countdown_section">
            <span id="minutes-{{ section.id }}" class="countdown_timer"></span>
            <span class="countdown_title">{{ settings.minute_title }}</span>
          </li>
          <li class="countdown_section">
            <span id="seconds-{{ section.id }}" class="countdown_timer"></span>
            <span class="countdown_title">{{ settings.second_title }}</span>
          </li>
        </ul>
      {% endif %}
      {%- if featured_tab_enable -%}
        <ul class="nav nav-tabs" role="tablist">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'product_tab' %}
                {% assign category_product = collections[block.settings.tab_product] %}
                <li role="presentation" data-fade-in>
                  <a
                    class="{% if forloop.first == true %}active show{% endif %}"
                    role="tab"
                    data-bs-toggle="tab"
                    href="#tab-{{ block.id }}">
                    {{- category_product.title | default: 'Collection' -}}
                  </a>
                </li>
            {% endcase %}
          {% endfor %}
        </ul>
        {% endif %}
    </div>
    {% endif %}
    <div class="collection-wrap">
      {%- if featured_tab_enable -%}
      <div class="tab-content tabs">
      {% endif %}
        {% for block in section.blocks %}
        {% case block.type %}
        {% when 'product_tab' %}
        {% assign category_product = collections[block.settings.tab_product] %}
        {%- if featured_tab_enable -%}
        <div class="tab-pane fade{% if forloop.first == true %} active show{% endif %}" id="tab-{{ block.id }}" role="tabpanel">
        {%- endif -%}
          <div class="grid-wrap featured-products-grid"
            style="--col-desktop: {{ section.settings.product_view }}; --col-tablet: {{ section.settings.product_view_lg }}; --col-mobile: {{ section.settings.product_view_sm }};">
            {% assign product_limit = section.settings.product_limit %}
            {% for product in category_product.products limit: product_limit %}
            <div class="grid-wrapper">
              {%- liquid
                if section.settings.category_special_product_view == 'grid'
                  render 'product-grid-item', product: product
                elsif section.settings.category_special_product_view == 'list'
                  render 'product-grid-list', product: product
                endif
              -%}
            </div>
            {% else %}
            {% for i in (1..product_limit) %}
            <div class="grid-wrapper">
              {% if section.settings.category_special_product_view == 'list' %}
              <div class="product-grid-list">
              {% endif %}
                <div class="single-product-wrap">
                  <div class="product-image">
                    {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                    {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                  </div>
                  <div class="product-content">
                    <div class="product-title">
                      <h6 class="mr-0">
                        <a>{{ 'homepage.sections.product_title' | t }}</a>
                      </h6>
                    </div>
                    <div class="price-box">
                      <span class="new-price">{{ 'homepage.sections.product_price' | t }}</span>
                    </div>
                  </div>
                </div>
              {% if section.settings.category_special_product_view == 'list' %}
              </div>
              {% endif %}
            </div>
            {% endfor %}
            {% endfor %}
          </div>
          {% if section.settings.view_btn != blank %}
          <div class="view-collection">
            <a class="btn-style" href="{{ category_product.url }}">
              {{ section.settings.view_btn }}
            </a>
          </div>
          {% endif %}
        {%- if featured_tab_enable -%}
        </div>
        {% endif %}
        {% endcase %}
        {% if section.settings.countdown_enable %}
        <script type="text/javascript">
          addEventListener('DOMContentLoaded', function() {
            const second = 1000, minute = second * 60, hour = minute * 60, day = hour * 24;
            let countDown = new Date('{{ section.settings.product_month }} {{ section.settings.product_date }}, {{ section.settings.product_year }} 00:00:00').getTime();
            setInterval(function() {
              let distance = countDown - new Date().getTime();
              document.getElementById('days-{{ section.id }}').innerText    = Math.floor(distance / day);
              document.getElementById('hours-{{ section.id }}').innerText   = Math.floor((distance % day) / hour);
              document.getElementById('minutes-{{ section.id }}').innerText = Math.floor((distance % hour) / minute);
              document.getElementById('seconds-{{ section.id }}').innerText = Math.floor((distance % minute) / second);
            }, second);
          });
        </script>
        {% endif %}
        {% endfor %}
        {%- if featured_tab_enable -%}
        </div>
      {% endif %}
    </div>
  </div>
</section>
